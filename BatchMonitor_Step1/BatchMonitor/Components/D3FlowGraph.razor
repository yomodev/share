@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="bm-d3-flow-graph" @ref="_containerRef">
    <button class="bm-graph-fit-btn" title="Fit to view" @onclick="FitToViewAsync">
        <MudIcon Icon="@Icons.Material.Outlined.CenterFocusWeak" Size="Size.Small" />
    </button>
</div>

@code {
    [Parameter, EditorRequired] public Topology Topology { get; set; } = new();

    private ElementReference _containerRef;
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("BatchMonitor.D3FlowGraphInterop.init", _containerRef, GetHandleKey());
                _initialized = true;
                await PushTopologyAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[D3FlowGraph] init failed: {ex.Message}");
            }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_initialized)
        {
            await PushTopologyAsync();
        }
    }

    private string GetHandleKey() => $"d3flowgraph-{GetHashCode()}";

    private async Task PushTopologyAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("BatchMonitor.D3FlowGraphInterop.update", GetHandleKey(), Topology);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[D3FlowGraph] update failed: {ex.Message}");
        }
    }

    private async Task FitToViewAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("BatchMonitor.D3FlowGraphInterop.fitToView", GetHandleKey());
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        if (_initialized)
        {
            try { await JS.InvokeVoidAsync("BatchMonitor.D3FlowGraphInterop.dispose", GetHandleKey()); }
            catch { }
        }
    }
}
