@inject EnvironmentSelectorService EnvService
@inject TabService TabService
@inject IBatchService BatchService
@implements IDisposable

<div class="bm-home">

    <!-- ── Header ─────────────────────────────────────────────────────── -->
    <div class="bm-home-header">
        <div>
            <MudText Typo="Typo.h5" Class="bm-home-title">Operations Centre</MudText>
            <MudText Typo="Typo.body2" Class="bm-home-subtitle">
                Real-time batch processing monitor
            </MudText>
        </div>
        <div class="bm-home-env">
            <MudSelect T="string"
                       Value="@EnvService.SelectedId"
                       ValueChanged="OnEnvChanged"
                       Dense="true"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Class="bm-home-env-select">
                @foreach (var env in EnvService.Environments)
                {
                    <MudSelectItem Value="@env.Id">
                        <div class="bm-env-option">
                            <span class="bm-env-badge"
                                  style="background:@env.BadgeColor; color:@env.BadgeTextColor">
                                @env.Id
                            </span>
                            <span class="bm-env-label">@env.Label</span>
                        </div>
                    </MudSelectItem>
                }
            </MudSelect>
        </div>
    </div>

    <!-- ── KPI cards ──────────────────────────────────────────────────── -->
    <MudGrid Spacing="3" Class="bm-stat-grid">
        <MudItem xs="12" sm="6" md="3">
            <div class="bm-stat-card">
                <div class="bm-stat-icon" style="background:rgba(63,185,80,0.12);">
                    <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Style="color:#3FB950;" />
                </div>
                <div class="bm-stat-body">
                    <MudText Class="bm-stat-value">@_runningCount</MudText>
                    <MudText Class="bm-stat-label">Running</MudText>
                </div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <div class="bm-stat-card">
                <div class="bm-stat-icon" style="background:rgba(47,129,244,0.12);">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="color:#2F81F4;" />
                </div>
                <div class="bm-stat-body">
                    <MudText Class="bm-stat-value">@_completedCount</MudText>
                    <MudText Class="bm-stat-label">Completed Today</MudText>
                </div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <div class="bm-stat-card">
                <div class="bm-stat-icon" style="background:rgba(248,81,73,0.12);">
                    <MudIcon Icon="@Icons.Material.Filled.Error" Style="color:#F85149;" />
                </div>
                <div class="bm-stat-body">
                    <MudText Class="bm-stat-value">@_failedCount</MudText>
                    <MudText Class="bm-stat-label">Failed</MudText>
                </div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <div class="bm-stat-card">
                <div class="bm-stat-icon" style="background:rgba(210,153,34,0.12);">
                    <MudIcon Icon="@Icons.Material.Outlined.Speed" Style="color:#D29922;" />
                </div>
                <div class="bm-stat-body">
                    <MudText Class="bm-stat-value">@_avgDuration</MudText>
                    <MudText Class="bm-stat-label">Avg Duration</MudText>
                </div>
            </div>
        </MudItem>
    </MudGrid>

    <!-- ── Mini batch summary ─────────────────────────────────────────── -->
    <MudPaper Elevation="0" Class="bm-mini-summary">
        <div class="bm-mini-summary-header">
            <MudText Typo="Typo.subtitle2" Class="bm-section-title">Recent Batches</MudText>
            <MudButton Variant="Variant.Text" Size="Size.Small"
                       StartIcon="@Icons.Material.Outlined.ViewList"
                       OnClick="OpenBatchesDashboard"
                       Class="bm-view-all-btn">
                View All
            </MudButton>
        </div>

        <MudTable T="BatchSummary"
                  Items="@_recent"
                  Dense="true"
                  Hover="true"
                  Elevation="0"
                  Class="bm-mini-table">
            <HeaderContent>
                <MudTh Style="width:36px;"></MudTh>
                <MudTh>Name</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Started</MudTh>
                <MudTh>Duration</MudTh>
                <MudTh Style="width:80px;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd><StatusIcon Status="@context.Status" /></MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2">@context.BatchName</MudText>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Class="bm-type-chip">@context.Type</MudChip>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Class="bm-monospace bm-muted">
                        @context.Start.ToString("HH:mm:ss") UTC
                    </MudText>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Class="bm-monospace bm-muted">
                        @FormatDuration(context.Duration)
                    </MudText>
                </MudTd>
                <MudTd Style="text-align:right;">
                    <MudTooltip Text="Open Detail">
                        <MudIconButton Icon="@Icons.Material.Outlined.OpenInNew"
                                       Size="Size.Small"
                                       OnClick="@(() => OpenDetail(context))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

</div>

@code {
    private int _runningCount   = 0;
    private int _completedCount = 0;
    private int _failedCount    = 0;
    private string _avgDuration = "--:--";
    private List<BatchSummary> _recent = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        EnvService.OnChange += OnEnvExternalChange;
    }

    private async Task LoadAsync()
    {
        try
        {
            var batches = await BatchService.GetBatchesAsync(
                EnvService.SelectedId, DateTime.UtcNow, 25);

            _recent         = batches.Take(5).ToList();
            _runningCount   = batches.Count(b => b.Status == BatchStatus.Running);
            _failedCount    = batches.Count(b => b.Status == BatchStatus.Failed);
            _completedCount = batches.Count(b => b.Status == BatchStatus.Completed);

            var completed = batches.Where(b => b.End.HasValue).ToList();
            if (completed.Any())
            {
                var avg = TimeSpan.FromSeconds(completed.Average(b => b.Duration.TotalSeconds));
                _avgDuration = FormatDuration(avg);
            }
        }
        catch { /* non-critical — show zeros */ }
    }

    private async void OnEnvExternalChange()
    {
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnEnvChanged(string newId)
    {
        EnvService.SelectedId = newId;
        await LoadAsync();
    }

    private void OpenBatchesDashboard() =>
        TabService.OpenOrFocus(TabModel.CreateBatchesDashboard(EnvService.SelectedId));

    private void OpenDetail(BatchSummary b) =>
        TabService.OpenOrFocus(TabModel.CreateBatchDetail(b.RunId, b.BatchName, EnvService.SelectedId));

    private static string FormatDuration(TimeSpan ts) =>
        ts.TotalHours >= 1
            ? $"{(int)ts.TotalHours:D2}:{ts.Minutes:D2}:{ts.Seconds:D2}"
            : $"{ts.Minutes:D2}:{ts.Seconds:D2}";

    public void Dispose() =>
        EnvService.OnChange -= OnEnvExternalChange;
}
