@page "/"
@namespace BatchMonitor.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Batch Monitor</title>
    <base href="~/" />

    <!-- Inter font from Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- MudBlazor CSS -->
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />

    <!-- Application CSS -->
    <link href="css/app.css" rel="stylesheet" />
</head>
<body>
    <component type="typeof(App)" render-mode="ServerPrerendered" />

    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>

    <!-- D3 v7 library -->
    <script src="https://d3js.org/d3.v7.min.js"></script>

    <!-- Dagre library for hierarchical layout -->
    <script src="https://dagrejs.github.io/project/dagre-d3/latest/dagre-d3.min.js"></script>

    <!-- Load MudBlazor script first, then append blazor.server.js once MudBlazor finished loading.
         This ensures MudBlazor registers its global JS functions (e.g. mudElementRef.*)
         before Blazor starts invoking them. A fallback loads blazor.server.js even if Mud fails. -->
    <script>
        (function(){
            var mud = document.createElement('script');
            mud.src = '_content/MudBlazor/MudBlazor.min.js';
            mud.onload = function() {
                var blazor = document.createElement('script');
                blazor.src = '_framework/blazor.server.js';
                document.body.appendChild(blazor);
            };
            mud.onerror = function() {
                // If MudBlazor fails to load, still start Blazor to show the error fast.
                var blazor = document.createElement('script');
                blazor.src = '_framework/blazor.server.js';
                document.body.appendChild(blazor);
            };
            // Insert Mud script synchronously into head so it begins loading immediately
            document.head.appendChild(mud);
        })();
    </script>

    <!-- Application JS files -->
    <script src="js/d3-graph.js"></script>
    <script src="js/app.js"></script>
</body>
</html>
