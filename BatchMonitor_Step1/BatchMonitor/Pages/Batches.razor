@inject IBatchService BatchService
@inject TabService TabService
@inject ISnackbar Snackbar
@implements IDisposable

<div class="bm-page bm-page-fill">

    <!-- ── Toolbar: filter + refresh ────────────────────────────────── -->
    <div class="bm-batch-toolbar">
        <MudTextField @bind-Value="_searchText"
                      Placeholder="Search name, run ID…"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Outlined.Search"
                      Immediate="true"
                      DebounceInterval="300"
                      OnDebounceIntervalElapsed="ApplyFilter"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Class="bm-filter-input"
                      Clearable="true"
                      OnClearButtonClick="ClearFilter" />

        <MudTooltip Text="Refresh">
            <MudIconButton Icon="@Icons.Material.Outlined.Refresh"
                           Size="Size.Small"
                           OnClick="RefreshAsync"
                           Class="bm-refresh-btn" />
        </MudTooltip>
    </div>

    <!-- ── Table ─────────────────────────────────────────────────────── -->
    <div class="bm-table-wrap">
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="bm-loading-bar" />
        }

        <MudTable T="BatchSummary"
                  Items="@_paged"
                  Dense="true"
                  Hover="true"
                  Elevation="0"
                  Class="bm-batch-table"
                  FixedHeader="true"
                  Height="100%">
            <HeaderContent>
                <MudTh Style="width:36px;"></MudTh>
                <MudTh>
                    <MudTableSortLabel T="BatchSummary"
                                       SortBy="@(b => b.BatchName)">Name</MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel T="BatchSummary"
                                       SortBy="@(b => b.RunId)">Run ID</MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel T="BatchSummary"
                                       SortBy="@(b => b.Type)">Type</MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel T="BatchSummary"
                                       SortBy="@(b => b.Start)" InitialDirection="SortDirection.Descending">
                        Started (UTC)
                    </MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel T="BatchSummary"
                                       SortBy="@(b => b.Duration)">Duration</MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel T="BatchSummary"
                                       SortBy="@(b => b.Status)">Status</MudTableSortLabel>
                </MudTh>
                <MudTh Style="width:110px; text-align:center;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="padding-left:12px;">
                    <StatusIcon Status="@context.Status" />
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2">@context.BatchName</MudText>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Class="bm-monospace bm-muted">@context.RunId</MudText>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Class="bm-type-chip">@context.Type</MudChip>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Class="bm-monospace bm-muted">
                        @context.Start.ToString("yyyy-MM-dd HH:mm:ss")
                    </MudText>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Class="bm-monospace">
                        @FormatDuration(context.Duration)
                    </MudText>
                </MudTd>
                <MudTd>
                    <span class="bm-status-text bm-status-@context.Status.ToString().ToLower()">
                        @context.Status
                    </span>
                </MudTd>
                <MudTd Style="text-align:center;">
                    <div class="bm-row-actions">
                        <MudTooltip Text="Open Detail">
                            <MudIconButton Icon="@Icons.Material.Outlined.OpenInNew"
                                           Size="Size.Small"
                                           OnClick="@(() => OpenDetail(context))" />
                        </MudTooltip>
                        <MudTooltip Text="Open Timeline">
                            <MudIconButton Icon="@Icons.Material.Outlined.Timeline"
                                           Size="Size.Small"
                                           OnClick="@(() => OpenTimeline(context))" />
                        </MudTooltip>
                        <MudTooltip Text="@(context.Status == BatchStatus.Running ? "Stop Batch" : "Not running")">
                            <span>
                                <MudIconButton Icon="@Icons.Material.Outlined.StopCircle"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               Disabled="@(context.Status != BatchStatus.Running)"
                                               OnClick="@(() => StopBatchAsync(context))" />
                            </span>
                        </MudTooltip>
                    </div>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </div>

    <!-- ── Footer: count + rows per page + pagination ────────────────── -->
    <div class="bm-batch-footer">
        <MudText Typo="Typo.body2" Class="bm-muted bm-footer-count">
            @_filtered.Count results
        </MudText>

        <MudPagination Count="@_totalPages"
                       Selected="@_page"
                       SelectedChanged="OnPageChanged"
                       ShowFirstButton="true"
                       ShowLastButton="true"
                       Size="Size.Small"
                       Class="bm-pagination-ctrl" />

        <div class="bm-rows-select">
            <MudText Typo="Typo.body2" Class="bm-muted" Style="white-space:nowrap;">Rows:</MudText>
            <MudSelect T="int"
                       Value="@_pageSize"
                       ValueChanged="OnPageSizeChanged"
                       Dense="true"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Style="width:74px;font-size:0.72rem">
                <MudSelectItem Value="10">10</MudSelectItem>
                <MudSelectItem Value="25">25</MudSelectItem>
                <MudSelectItem Value="50">50</MudSelectItem>
                <MudSelectItem Value="100">100</MudSelectItem>
            </MudSelect>
        </div>
    </div>

</div>

@code {
    [Parameter, EditorRequired] public string Environment { get; set; } = string.Empty;

    private int _page     = 1;
    private int _pageSize = 25;
    private bool _loading = false;
    private string _searchText = string.Empty;

    private List<BatchSummary> _all      = new();
    private List<BatchSummary> _filtered = new();
    private List<BatchSummary> _paged    = new();
    private int _totalPages => Math.Max(1, (int)Math.Ceiling((double)_filtered.Count / _pageSize));

    private CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync() =>
        await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _all = await BatchService.GetBatchesAsync(
                Environment, DateTime.UtcNow, 200, ct: _cts.Token);
            ApplyFilter();
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load batches: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyFilter()
    {
        var filter = string.IsNullOrWhiteSpace(_searchText)
            ? _all
            : _all.Where(b =>
                b.BatchName.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                b.RunId.Contains(_searchText, StringComparison.OrdinalIgnoreCase)).ToList();

        _filtered = filter;
        _page     = 1;
        RebuildPage();
        StateHasChanged();
    }

    private void ClearFilter()
    {
        _searchText = string.Empty;
        ApplyFilter();
    }

    private void RebuildPage() =>
        _paged = _filtered.Skip((_page - 1) * _pageSize).Take(_pageSize).ToList();

    private void OnPageChanged(int page) { _page = page; RebuildPage(); }

    private void OnPageSizeChanged(int size) { _pageSize = size; _page = 1; RebuildPage(); }

    private async Task RefreshAsync()
    {
        _searchText = string.Empty;
        await LoadAsync();
        Snackbar.Add("Refreshed", Severity.Normal, c => c.VisibleStateDuration = 1500);
    }

    private void OpenDetail(BatchSummary b) =>
        TabService.OpenOrFocus(TabModel.CreateBatchDetail(b.RunId, b.BatchName, Environment));

    private void OpenTimeline(BatchSummary b) =>
        TabService.OpenOrFocus(TabModel.CreateTimeline(b.RunId, Environment));

    private async Task StopBatchAsync(BatchSummary b)
    {
        var ok = await BatchService.CancelBatchAsync(Environment, b.RunId, _cts.Token);
        if (ok)
        {
            Snackbar.Add($"Stop requested for {b.BatchName}", Severity.Warning);
            await LoadAsync();
        }
        else
            Snackbar.Add("Could not stop batch", Severity.Error);
    }

    private static string FormatDuration(TimeSpan ts) =>
        ts.TotalHours >= 1
            ? $"{(int)ts.TotalHours:D2}:{ts.Minutes:D2}:{ts.Seconds:D2}"
            : $"{ts.Minutes:D2}:{ts.Seconds:D2}";

    public void Dispose() => _cts.Cancel();
}
