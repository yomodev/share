@inject TabService TabService
@inject ISnackbar Snackbar

<div class="bm-page">

    <!-- ── Page header ────────────────────────────────────────────────── -->
    <div class="bm-page-header">
        <MudText Typo="Typo.h6" Class="bm-page-title">
            <MudIcon Icon="@Icons.Material.Outlined.ViewList" Class="mr-2" Size="Size.Small" />
            Batches
        </MudText>
        <MudText Typo="Typo.body2" Class="bm-muted">@Environment</MudText>
    </div>

    <!-- ── Batch table ────────────────────────────────────────────────── -->
    <MudPaper Elevation="0" Class="bm-table-paper">

        <!-- Toolbar: refresh + rows-per-page -->
        <div class="bm-table-toolbar">
            <MudText Typo="Typo.body2" Class="bm-muted">
                Showing @_paged.Count of @_filtered.Count batches
            </MudText>
            <div class="bm-toolbar-right">
                <MudSelect T="int"
                           Value="@_pageSize"
                           ValueChanged="OnPageSizeChanged"
                           Dense="true"
                           Variant="Variant.Outlined"
                           Label="Rows"
                           Style="width:90px;"
                           Margin="Margin.Dense">
                    <MudSelectItem Value="10">10</MudSelectItem>
                    <MudSelectItem Value="25">25</MudSelectItem>
                    <MudSelectItem Value="50">50</MudSelectItem>
                    <MudSelectItem Value="100">100</MudSelectItem>
                </MudSelect>
                <MudIconButton Icon="@Icons.Material.Outlined.Refresh"
                               Size="Size.Small"
                               Title="Refresh"
                               OnClick="Refresh"
                               Class="ml-2" />
            </div>
        </div>

        <MudTable Items="@_paged"
                  Dense="true"
                  Hover="true"
                  Elevation="0"
                  Class="bm-batch-table"
                  FixedHeader="true"
                  Height="calc(100vh - 260px)">
            <HeaderContent>
                <MudTh Style="width:36px; padding-left:16px;"></MudTh>
                <MudTh>Name</MudTh>
                <MudTh>Run ID</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Started (UTC)</MudTh>
                <MudTh>Duration</MudTh>
                <MudTh Style="width:120px; text-align:center;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="padding-left:16px;">
                    <StatusIcon Status="@context.Status" />
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2">@context.BatchName</MudText>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Class="bm-monospace bm-muted">@context.RunId</MudText>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Class="bm-type-chip">@context.Type</MudChip>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Class="bm-monospace bm-muted">
                        @context.Start.ToString("yyyy-MM-dd HH:mm:ss")
                    </MudText>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Class="bm-monospace">
                        @FormatDuration(context.Duration)
                    </MudText>
                </MudTd>
                <MudTd Style="text-align:center;">
                    <div class="bm-row-actions">
                        <!-- Open detail tab -->
                        <MudTooltip Text="Open Detail">
                            <MudIconButton Icon="@Icons.Material.Outlined.OpenInNew"
                                           Size="Size.Small"
                                           OnClick="@(() => OpenDetail(context))" />
                        </MudTooltip>

                        <!-- Open timeline tab -->
                        <MudTooltip Text="Open Timeline">
                            <MudIconButton Icon="@Icons.Material.Outlined.Timeline"
                                           Size="Size.Small"
                                           OnClick="@(() => OpenTimeline(context))" />
                        </MudTooltip>

                        <!-- Stop batch — enabled only when Running -->
                        <MudTooltip Text="@(context.Status == BatchStatus.Running ? "Stop Batch" : "Not running")">
                            <span>
                                <MudIconButton Icon="@Icons.Material.Outlined.StopCircle"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               Disabled="@(context.Status != BatchStatus.Running)"
                                               OnClick="@(() => StopBatch(context))" />
                            </span>
                        </MudTooltip>
                    </div>
                </MudTd>
            </RowTemplate>
        </MudTable>

        <!-- ── Pagination ─────────────────────────────────────────────── -->
        <div class="bm-pagination">
            <MudText Typo="Typo.body2" Class="bm-muted">
                Page @_page of @_totalPages
            </MudText>
            <MudPagination Count="@_totalPages"
                           Selected="@_page"
                           SelectedChanged="OnPageChanged"
                           ShowFirstButton="true"
                           ShowLastButton="true"
                           Size="Size.Small" />
        </div>

    </MudPaper>

</div>

@code {
    [Parameter, EditorRequired] public string Environment { get; set; } = string.Empty;

    private int _page     = 1;
    private int _pageSize = 25;

    private List<BatchSummary> _all      = new();
    private List<BatchSummary> _filtered = new();
    private List<BatchSummary> _paged    = new();
    private int _totalPages => Math.Max(1, (int)Math.Ceiling((double)_filtered.Count / _pageSize));

    protected override void OnInitialized()
    {
        LoadMockData();
        ApplyFilter();
    }

    // ── Mock data (replaced by real endpoint in Step 2) ──────────────

    private void LoadMockData()
    {
        var rng   = new Random(42);
        var types = new[] { "FullLoad", "DeltaSync", "Reconcile", "Archive" };
        var names = new[] { "Customers", "Orders", "Products", "Inventory", "Pricing", "Contracts", "Shipments" };

        _all = Enumerable.Range(1, 120).Select(i =>
        {
            var start  = DateTime.UtcNow.AddMinutes(-rng.Next(1, 1440));
            var status = i switch { 1 => BatchStatus.Running, 2 => BatchStatus.Running, 3 => BatchStatus.Failed, _ => BatchStatus.Completed };
            return new BatchSummary
            {
                RunId     = $"RUN-{DateTime.UtcNow:yyyyMMdd}-{i:D3}",
                BatchName = $"{types[rng.Next(types.Length)]}_{names[rng.Next(names.Length)]}",
                Type      = types[rng.Next(types.Length)],
                Status    = status,
                Start     = start,
                End       = status != BatchStatus.Running ? start.AddMinutes(rng.Next(2, 30)) : null
            };
        })
        .OrderByDescending(b => b.Start)
        .ToList();
    }

    private void ApplyFilter()
    {
        _filtered = _all; // filter logic added in Step 3
        _page     = 1;
        RebuildPage();
    }

    private void RebuildPage()
    {
        _paged = _filtered
            .Skip((_page - 1) * _pageSize)
            .Take(_pageSize)
            .ToList();
    }

    private void OnPageChanged(int page)
    {
        _page = page;
        RebuildPage();
    }

    private void OnPageSizeChanged(int size)
    {
        _pageSize = size;
        _page     = 1;
        RebuildPage();
    }

    private void Refresh()
    {
        LoadMockData();
        ApplyFilter();
        Snackbar.Add("Refreshed", Severity.Normal, cfg => cfg.VisibleStateDuration = 1500);
    }

    private void OpenDetail(BatchSummary batch) =>
        TabService.OpenOrFocus(TabModel.CreateBatchDetail(batch.RunId, batch.BatchName, Environment));

    private void OpenTimeline(BatchSummary batch) =>
        TabService.OpenOrFocus(TabModel.CreateTimeline(batch.RunId, Environment));

    private void StopBatch(BatchSummary batch)
    {
        // POST /api/{env}/batches/{runId}/cancel — wired in Step 2
        Snackbar.Add($"Stop requested for {batch.BatchName}", Severity.Warning);
    }

    private static string FormatDuration(TimeSpan ts) =>
        ts.TotalHours >= 1
            ? $"{(int)ts.TotalHours:D2}:{ts.Minutes:D2}:{ts.Seconds:D2}"
            : $"{ts.Minutes:D2}:{ts.Seconds:D2}";
}
