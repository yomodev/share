@inject TabService TabService
@inject EnvironmentSelectorService EnvService
@implements IDisposable

<div class="bm-tabbar-inner">

    <!-- ── Home button (always visible, left anchor) ─────────────────── -->
    <div class="bm-tab-home @(TabService.ActiveTab is null ? "active" : "")"
         @onclick="() => TabService.GoHome()">
        <MudIcon Icon="@Icons.Material.Outlined.Home" Size="Size.Small" />
    </div>

    <div class="bm-tab-divider"></div>

    <!-- ── Visible tabs ──────────────────────────────────────────────── -->
    <div class="bm-tabs-scroll">
        @foreach (var tab in TabService.Tabs)
        {
            <div class="bm-tab @(tab.IsActive ? "active" : "")"
                 @onclick="() => TabService.Focus(tab.Id)"
                 @key="tab.Id">

                <MudIcon Icon="@tab.Icon" Size="Size.Small" Class="bm-tab-icon" />

                <span class="bm-tab-label">@tab.Label</span>

                @if (tab.Environment is not null)
                {
                    var env = EnvService.Environments.FirstOrDefault(e => e.Id == tab.Environment);
                    if (env is not null)
                    {
                        <span class="bm-tab-env-badge"
                              style="background:@env.BadgeColor; color:@env.BadgeTextColor">
                            @env.Id
                        </span>
                    }
                }

                <span @onclick="@(() => TabService.Close(tab.Id))"
                      @onclick:stopPropagation="true"
                      class="bm-tab-close-wrap">
                    <MudIconButton Icon="@Icons.Material.Outlined.Close"
                                   Size="Size.Small"
                                   Class="bm-tab-close" />
                </span>
            </div>
        }
    </div>

    <!-- ── Overflow menu ─────────────────────────────────────────────── -->
    @if (TabService.Tabs.Count > 0)
    {
        <MudMenu Icon="@Icons.Material.Outlined.KeyboardArrowDown"
                 Size="Size.Small"
                 Dense="true"
                 Class="bm-tab-overflow"
                 AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight">
            @foreach (var tab in TabService.Tabs)
            {
                <MudMenuItem OnClick="() => TabService.Focus(tab.Id)">
                    <div class="bm-overflow-item">
                        <MudIcon Icon="@tab.Icon" Size="Size.Small" Class="mr-2" />
                        <span>@tab.Label</span>
                        @if (tab.Environment is not null)
                        {
                            <span class="bm-overflow-env ml-2">@tab.Environment</span>
                        }
                    </div>
                </MudMenuItem>
            }
        </MudMenu>
    }

</div>

@code {
    protected override void OnInitialized() =>
        TabService.OnChange += StateHasChanged;

    public void Dispose() =>
        TabService.OnChange -= StateHasChanged;
}
