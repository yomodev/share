<?xml version="1.0" encoding="utf-8" ?>
<!--
  ANSI color codes used below (&#27; = ESC):
    96  bright cyan     → timestamp
    35  magenta         → thread id
    93  bright yellow   → caller method
    90  dark gray       → TRACE
    37  light gray      → DEBUG
    92  bright green    → INFO
    33  yellow          → WARN
    91  bright red      → ERROR
    95  bright magenta  → FATAL
     0  reset
-->
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">

  <variable name="clr_reset"  value="&#27;[0m" />
  <variable name="clr_time"   value="&#27;[96m" />
  <variable name="clr_tid"    value="&#27;[35m" />
  <variable name="clr_caller" value="&#27;[93m" />

  <!-- level color: pick the right ANSI code based on level -->
  <variable name="clr_level"
    value="${when:when=level==LogLevel.Trace:inner=&#27;[90m}${when:when=level==LogLevel.Debug:inner=&#27;[37m}${when:when=level==LogLevel.Info:inner=&#27;[92m}${when:when=level==LogLevel.Warn:inner=&#27;[33m}${when:when=level==LogLevel.Error:inner=&#27;[91m}${when:when=level==LogLevel.Fatal:inner=&#27;[95m}" />

  <targets>
    <target xsi:type="Console" name="console"
            layout="${clr_time}${date:format=HH\:mm\:ss.fff}${clr_reset} ${clr_tid}[${threadid:padding=3}]${clr_reset} ${clr_level}${pad:padding=-5:inner=${level:uppercase=true}}${clr_reset} ${clr_caller}${logger:shortName=true}${clr_reset} ${message} ${exception:format=tostring}" />

    <!-- Diagnostics monitor: plain-text rolling file, one per day, kept 14 days -->
    <target xsi:type="File" name="diag-file"
            fileName="${basedir}/logs/diagnostics.log"
            archiveFileName="${basedir}/logs/diagnostics.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Date"
            archiveDateFormat="yyyy-MM-dd"
            maxArchiveFiles="14"
            concurrentWrites="false"
            keepFileOpen="true"
            layout="${date:format=yyyy-MM-dd HH\:mm\:ss.fff} [${level:uppercase=true}] ${logger:shortName=true} ${message} ${exception:format=tostring}" />
  </targets>

  <rules>
    <!-- suppress noisy framework internals -->
    <logger name="Microsoft.*"                         maxlevel="Info" final="true" />
    <logger name="System.*"                            maxlevel="Info" final="true" />
    <logger name="Microsoft.Extensions.Localization.*" maxlevel="Warn" final="true" />

    <!-- diagnostics monitor → console + file -->
    <logger name="NxtUI.Web.Services.ServerDiagnosticsMonitor" minlevel="Debug" writeTo="console,diag-file" final="true" />

    <!-- app code at Debug and above -->
    <logger name="NxtUI.*" minlevel="Debug" writeTo="console" />

    <!-- everything else at Info and above -->
    <logger name="*"       minlevel="Info"  writeTo="console" />
  </rules>

</nlog>
