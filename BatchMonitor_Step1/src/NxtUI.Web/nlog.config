<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">

  <targets>
    <!-- ColoredConsole instead of raw ANSI escape codes: NLog config files are XML, and
         the ESC control character (0x1B) is not a legal XML character at all — even the
         numeric entity &#27; decodes to an illegal document, so a hand-rolled ANSI/Console
         target here can never actually parse. ColoredConsole recolors matched regions of
         the already-rendered line instead of requiring escape bytes in the config itself.
         Layout order: timestamp, thread, level, message/exception, then the calling
         class+method last (callsite gives class+method; logger:shortName only gives the
         class). -->
    <target xsi:type="ColoredConsole" name="console"
            useDefaultRowHighlightingRules="false"
            layout="${date:format=HH\:mm\:ss.fff} ${threadid:padding=3} ${pad:padding=-5:inner=${level:uppercase=true}} ${message} ${exception:format=tostring} ${callsite:className=true:methodName=true:fileName=false}">
      <highlight-word regex="^\d{2}:\d{2}:\d{2}\.\d{3}" foregroundColor="Cyan" />
      <highlight-word regex="\d+(?=\s+(TRACE|DEBUG|INFO|WARN|ERROR|FATAL))" foregroundColor="DarkMagenta" />
      <highlight-word regex="\bTRACE\b" foregroundColor="DarkGray" />
      <highlight-word regex="\bDEBUG\b" foregroundColor="DarkCyan" />
      <highlight-word regex="\bINFO\b"  foregroundColor="Green" />
      <highlight-word regex="\bWARN\b"  foregroundColor="DarkYellow" />
      <highlight-word regex="\bERROR\b" foregroundColor="Red" />
      <highlight-word regex="\bFATAL\b" foregroundColor="Magenta" />
      <!-- Caller (class+method) is always the last token on the line. -->
      <highlight-word regex="[\w.]+$" foregroundColor="DarkGray" />
    </target>

    <!-- General app-code file logging: one folder per process run (timestamped by
         process start time + PID), one file PER CLASS (${logger:shortName=true}.log).
         Every NxtUI.* logger writes here in addition to whatever shared topic file it's
         also routed to below (Mongo/Kafka/Sql/disk/diagnostics) — so there's always a
         single-class view of exactly what one component logged, even for classes whose
         messages are also bucketed into a shared file with other related classes.
         Layout: timestamp|loglevel|threadid|message|method. -->
    <target xsi:type="File" name="file"
            fileName="C:/temp/logs/NxtUI_${processinfo:property=StartTime:format=yyyyMMdd_HHmmss}_PID_${processid}/${logger:shortName=true}.log"
            layout="${date:format=yyyy-MM-dd HH\:mm\:ss.fff:universalTime=true}|${level:uppercase=true}|${threadid}|${message} ${exception:format=tostring}|${callsite:className=false:methodName=true:fileName=false}"
            keepFileOpen="true"
            concurrentWrites="false"
            encoding="utf-8"
            createDirs="true" />

    <!-- Diagnostics monitor: plain-text rolling file, one per day, kept 14 days -->
    <target xsi:type="File" name="diag-file"
            fileName="C:/temp/logs/diagnostics.log"
            archiveFileName="C:/temp/logs/diagnostics.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Date"
            archiveDateFormat="yyyy-MM-dd"
            maxArchiveFiles="14"
            concurrentWrites="false"
            keepFileOpen="true"
            layout="${date:format=yyyy-MM-dd HH\:mm\:ss.fff} [${level:uppercase=true}] ${logger:shortName=true} ${message} ${exception:format=tostring}" />

    <!-- Mongo queries (MongoService's LogDebug calls: rendered filters, sort/skip/limit,
         AST -> Mongo translation): plain-text rolling file, one per day, kept 14 days -->
    <target xsi:type="File" name="mongo-file"
            fileName="C:/temp/logs/mongo-queries.log"
            archiveFileName="C:/temp/logs/mongo-queries.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Date"
            archiveDateFormat="yyyy-MM-dd"
            maxArchiveFiles="14"
            concurrentWrites="false"
            keepFileOpen="true"
            layout="${date:format=yyyy-MM-dd HH\:mm\:ss.fff} [${level:uppercase=true}] ${logger:shortName=true} ${message} ${exception:format=tostring}" />

    <!-- Kafka (topic browsing/admin calls in KafkaService, plus the metrics consumer's
         source-of-truth decisions in ServiceMetricsMonitor: consumer start/stop, whether an
         env is getting live data from Kafka or falling back to disk, and any consume/seek
         errors): plain-text rolling file, one per day, kept 14 days. Check this file first
         when diagnosing whether metrics for an environment are coming from Kafka or disk. -->
    <target xsi:type="File" name="kafka-file"
            fileName="C:/temp/logs/kafka.log"
            archiveFileName="C:/temp/logs/kafka.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Date"
            archiveDateFormat="yyyy-MM-dd"
            maxArchiveFiles="14"
            concurrentWrites="false"
            keepFileOpen="true"
            layout="${date:format=yyyy-MM-dd HH\:mm\:ss.fff} [${level:uppercase=true}] ${logger:shortName=true} ${message} ${exception:format=tostring}" />

    <!-- SQL (SqlRunService's run-list/run-events queries: start/duration/error via
         OperationLog): plain-text rolling file, one per day, kept 14 days. -->
    <target xsi:type="File" name="sql-file"
            fileName="C:/temp/logs/sql.log"
            archiveFileName="C:/temp/logs/sql.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Date"
            archiveDateFormat="yyyy-MM-dd"
            maxArchiveFiles="14"
            concurrentWrites="false"
            keepFileOpen="true"
            layout="${date:format=yyyy-MM-dd HH\:mm\:ss.fff} [${level:uppercase=true}] ${logger:shortName=true} ${message} ${exception:format=tostring}" />

    <!-- Disk/file search and discovery (LogBrowserService's recursive file search,
         LogPathDiscoveryService's on-disk folder discovery): plain-text rolling file,
         one per day, kept 14 days. Check this file first for slow file-server searches. -->
    <target xsi:type="File" name="disk-file"
            fileName="C:/temp/logs/disk-search.log"
            archiveFileName="C:/temp/logs/disk-search.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Date"
            archiveDateFormat="yyyy-MM-dd"
            maxArchiveFiles="14"
            concurrentWrites="false"
            keepFileOpen="true"
            layout="${date:format=yyyy-MM-dd HH\:mm\:ss.fff} [${level:uppercase=true}] ${logger:shortName=true} ${message} ${exception:format=tostring}" />
  </targets>

  <rules>
    <!-- suppress noisy framework internals -->
    <logger name="Microsoft.*"                         maxlevel="Info" final="true" />
    <logger name="System.*"                            maxlevel="Info" final="true" />
    <logger name="Microsoft.Extensions.Localization.*" maxlevel="Warn" final="true" />

    <!-- diagnostics monitor → console + shared diag file + its own per-class file -->
    <logger name="NxtUI.Web.Services.ServerDiagnosticsMonitor" minlevel="Debug" writeTo="console,diag-file,file" final="true" />

    <!-- mongo queries → console + shared mongo file + per-class file -->
    <logger name="NxtUI.Core.Services.Mongo.*" minlevel="Debug" writeTo="console,mongo-file,file" final="true" />

    <!-- kafka (topic browsing/admin + metrics consumer) → console + shared kafka file + per-class file -->
    <logger name="NxtUI.Core.Services.Kafka.*"          minlevel="Debug" writeTo="console,kafka-file,file" final="true" />
    <logger name="NxtUI.Web.Services.ServiceMetricsMonitor" minlevel="Debug" writeTo="console,kafka-file,file" final="true" />

    <!-- sql (run list / run events queries) → console + shared sql file + per-class file -->
    <logger name="NxtUI.Core.Services.Sql.*" minlevel="Debug" writeTo="console,sql-file,file" final="true" />

    <!-- disk/file search and discovery → console + shared disk file + per-class file. LogPathDiscoveryService's
         actual filesystem-search chatter (every template tried, every folder found/not-found) is
         Trace level — file-only, never console, so it's available for deep debugging
         without flooding the console on every heartbeat/discovery pass. -->
    <logger name="NxtUI.Web.Services.LogBrowserService"          minlevel="Debug" writeTo="console,disk-file,file" final="true" />
    <logger name="NxtUI.Core.Services.LogPathDiscoveryService"   levels="Trace"   writeTo="disk-file,file"          final="true" />
    <logger name="NxtUI.Core.Services.LogPathDiscoveryService"   minlevel="Debug" writeTo="console,disk-file,file" final="true" />

    <!-- app code at Debug and above → console + per-class file -->
    <logger name="NxtUI.*" minlevel="Debug" writeTo="console,file" />

    <!-- ASP.NET/hosting warnings also go to file for post-mortem debugging -->
    <logger name="Microsoft.AspNetCore.*" minlevel="Warn" writeTo="file" />
    <logger name="Microsoft.Hosting.*"    minlevel="Warn" writeTo="file" />

    <!-- everything else at Info and above -->
    <logger name="*"       minlevel="Info"  writeTo="console" />
  </rules>

</nlog>
