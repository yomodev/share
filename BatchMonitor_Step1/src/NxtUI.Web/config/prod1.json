    "SaslPassword": "change-me"
  },
  "Mongo": {
    "ConnectionString": "mongodb+srv://mongo-prod-cluster.example.com/?replicaSet=rs0&tls=true",
    "DatabasePrefix": "BatchMonitor",
    "Username": "nxtui-prod",
    "Password": "change-me"
  }
}
