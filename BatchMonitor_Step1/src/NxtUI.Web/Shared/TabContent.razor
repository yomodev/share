@namespace NxtUI.Shared
@* Routes the active tab to its correct page component *@

@if (Tab is not null)
{
    @RenderTab()
}

@code {
    [Parameter, EditorRequired] public TabModel? Tab { get; set; }

    private RenderFragment RenderTab()
    {
        var env   = Tab!.Environment ?? string.Empty;
        var label = Tab.Label ?? string.Empty;

        return Tab.Type switch
        {
            TabType.Runs =>
                @<Runs Environment="@env" />,

            TabType.RunDetail =>
                @<RunDetail RunId="@Tab.EntityId" Environment="@env" Tab="@Tab" IsFocused="@Tab.IsActive" />,

            TabType.Services =>
                @<ServicesPage Env="@env" />,

            TabType.Pipelines =>
                @<PlaceholderPage Title="Pipelines" Icon="@Icons.Material.Outlined.AccountTree" Environment="@env" />,

            TabType.Kafka =>
                @<KafkaDashboard Environment="@env" />,

            TabType.KafkaGroups =>
                @<KafkaGroupsDashboard Environment="@env" />,

            TabType.MongoDB =>
                @<MongoDashboard Environment="@env" />,

            TabType.MongoDetail =>
                @<MongoCollectionInspector EntityId="@(Tab.EntityId ?? string.Empty)" Environment="@env" />,

            TabType.Batches =>
                @<Batches Environment="@env" />,

            TabType.Config =>
                @<PlaceholderPage Title="Config" Icon="@Icons.Material.Outlined.Tune" Environment="@env" />,

            TabType.MemoryGraph =>
                @<MemoryGraph Env="@env" />,

            TabType.LogBrowser =>
                @<LogBrowser Env="@env" NavigationHint="@Tab.NavigationHint" />,

            TabType.LogViewer =>
                @<LogViewer Path="@Tab.EntityId" Env="@env" FileName="@Tab.Label" />,

            TabType.LogWorkspace =>
                @<LogWorkspace Path="@Tab.EntityId" Env="@env" FileName="@Tab.Label" />,

            TabType.Settings =>
                @<Settings />,

            TabType.Timeline =>
                @<TimelineTab Tab="@Tab" Environment="@env" InitialRunId="@Tab.EntityId" IsFocused="@Tab.IsActive" />,

            TabType.KafkaMessages =>
                @<KafkaTopicInspector TopicName="@(Tab.EntityId ?? string.Empty)" Environment="@env" />,

            TabType.FilterHelp =>
                @<FilterHelp />,

            _ =>
                @<PlaceholderPage Title="@label" Icon="@Icons.Material.Outlined.Dashboard" Environment="@env" />,
        };
    }
}
