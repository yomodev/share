@* Routes the active tab to its correct page component *@

@if (Tab is null) { return; }

@{
    var env = Tab.Environment ?? string.Empty;
    var label = Tab.Label ?? string.Empty;
}

@switch (Tab.Type)
{
    case TabType.Batches:
        <BatchMonitor.Pages.Batches Environment="@env" />
        break;

    case TabType.BatchDetail:
        <BatchMonitor.Pages.BatchDetail RunId="@Tab.EntityId" Environment="@env" Tab="@Tab" IsFocused="@Tab.IsActive" />
        break;

    case TabType.Services:
        <BatchMonitor.Pages.PlaceholderPage Title="Services"
            Icon="@Icons.Material.Outlined.Dns" Environment="@env" />
        break;

    case TabType.Kafka:
        <BatchMonitor.Pages.KafkaDashboard Environment="@env" />
        break;

    case TabType.KafkaGroups:
        <BatchMonitor.Pages.KafkaGroupsDashboard Environment="@env" />
        break;

    case TabType.MongoDB:
        <BatchMonitor.Pages.MongoDashboard Environment="@env" />
        break;

    case TabType.MongoDetail:
        <BatchMonitor.Pages.MongoCollectionInspector EntityId="@(Tab.EntityId ?? string.Empty)" Environment="@env" />
        break;

    case TabType.Logs:
        <BatchMonitor.Pages.PlaceholderPage Title="Logs"
            Icon="@Icons.Material.Outlined.Article" Environment="@env" />
        break;

    case TabType.Settings:
        <BatchMonitor.Pages.Settings />
        break;

    case TabType.Timeline:
        <BatchMonitor.Pages.TimelineTab
            Tab="@Tab"
            Environment="@env"
            InitialRunId="@Tab.EntityId"
            IsFocused="@Tab.IsActive" />
        break;

    case TabType.KafkaDetail:
        <BatchMonitor.Pages.KafkaTopicInspector TopicName="@(Tab.EntityId ?? string.Empty)" Environment="@env" />
        break;

    case TabType.FilterHelp:
        <BatchMonitor.Pages.FilterHelp />
        break;

    default:
        <BatchMonitor.Pages.PlaceholderPage Title="@label"
            Icon="@Icons.Material.Outlined.Dashboard" Environment="@env" />
        break;
}

@code {
    [Parameter, EditorRequired] public TabModel? Tab { get; set; }
}
