@namespace NxtUI.Shared
@* Status icon with colour and pulse animation for Running *@

<MudTooltip Text="@Status.ToString()">
    <span class="bm-status-icon bm-status-@(Status.ToString().ToLower())">
        <MudIcon Icon="@GetIcon()" Size="@Size" />
    </span>
</MudTooltip>

@code {
    [Parameter, EditorRequired] public RunStatus Status { get; set; }
    [Parameter] public Size Size { get; set; } = Size.Small;

    private string GetIcon() => Status switch
    {
        RunStatus.Running    => Icons.Material.Filled.PlayCircle,
        RunStatus.Completed  => Icons.Material.Filled.CheckCircle,
        RunStatus.Failed     => Icons.Material.Filled.Error,
        RunStatus.Terminated => Icons.Material.Filled.StopCircle,
        RunStatus.Purged     => Icons.Material.Filled.DeleteSweep,
        _                    => Icons.Material.Outlined.HelpOutline
    };
}
