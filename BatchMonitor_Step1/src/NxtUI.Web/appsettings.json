{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Kafka": {
    "BootstrapServers": "localhost:9092"
  },

  "Mongo": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabasePrefix": "BatchMonitor",
    "PerformanceTrackerCollection": "PerformanceTracker",
    "HeartbeatsCollection": "Heartbeats"
  },

  "Heartbeats": {
    "CollectionName": "Heartbeats",
    "IntervalSeconds": 30
  },

  "Logs": {
    "ServiceTemplates": [
      "\\\\{server}\\Shared\\bau\\logs\\{date}\\Services\\{service}_{env}\\{server}_*_Pid_{pid}"
    ],
    "MetricsFileName": "Metrics.log",
    "MetricsIntervalSeconds": 90,
    "LogsFolder": "\\\\{server}\\Shared\\bau\\logs",
    "Servers": [],
    "FolderScanIntervalSeconds": 30,
    "FolderScanMinIntervalSeconds": 10
  },

  "TestLogGenerator": {
    "Enabled": false,
    "WriteIntervalSeconds": 15,
    "InitialLineCount": 5,
    "TemplateIndex": 0
  },

  "App": {
    "DefaultEnvironment": "DEV1",
    "DefaultPageSize": 25,
    "Environments": [
      { "Id": "DEV1",  "Label": "Development 1", "Tier": "Development", "Servers": [ "dev1-srv-01", "dev1-srv-02" ] },
      { "Id": "DEV2",  "Label": "Development 2", "Tier": "Development", "Servers": [ "dev2-srv-01" ] },
      { "Id": "UAT1",  "Label": "UAT 1",          "Tier": "UAT",         "Servers": [ "uat1-srv-01", "uat1-srv-02" ] },
      { "Id": "UAT2",  "Label": "UAT 2",          "Tier": "UAT",         "Servers": [ "uat2-srv-01" ] },
      { "Id": "STG1",  "Label": "Staging 1",      "Tier": "Staging",     "Servers": [ "stg1-srv-01", "stg1-srv-02" ] },
      { "Id": "PROD1", "Label": "Production 1",   "Tier": "Production",  "Servers": [ "prod-srv-01", "prod-srv-02", "prod-srv-03" ] }
    ]
  }
}
