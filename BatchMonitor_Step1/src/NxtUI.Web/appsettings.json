{
  "AllowedHosts": "*",

  "Ui": {
    // Debounce (ms) for FilterBox inputs before firing the query. Per-component override possible.
    "FilterDebounceMs": 500,
    // Words stripped from displayed service/pipeline labels (run-detail graph + Services
    // card view) to save horizontal space. {EnvID} is replaced with the current env id first.
    "LabelStripWords": [ "Pipeline", "ABC", "{EnvID}" ]
  },

  "Home": {
    // Whether the Home page shows the Memory treemap section. Disable if memory metrics
    // aren't wired up for a deployment.
    "ShowMemoryDashboard": true,
    // Number of most-recent runs shown in the Home page's "Recent Runs" panel.
    "RecentRunsCount": 20
  },

  "Timeline": {
    // Delay (ms) before the Timeline highlights same-id blocks on hover. 0 (default) = immediate.
    "HighlightDelayMs": 200,
    // Delay (ms) before the Timeline shows the hover popup/tooltip. 0 (default) = immediate.
    "PopupDelayMs": 500
  },

  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "TopicDeserializers": [
      {
        "Pattern": "orders.*",
        "Types": [ "OrderEvent" ]
      },
      {
        "Pattern": "payments.*",
        "Types": [ "PaymentEvent" ]
      },
      {
        "Pattern": "*.events",
        "Types": [ "OrderEvent", "PaymentEvent" ]
      },
      {
        "Pattern": "metrics",
        "Types": [ "MetricsTracker" ]
      }
    ],
    "DefaultProtoType": "ProtoMsg"
  },

  "Mongo": {
    // Connection string TEMPLATE, shared by every environment. The {server} token (if
    // present) is substituted with that environment's own Mongo:ServerName from
    // config/{env}.json — e.g. "mongodb://{server}:27017/?connectTimeoutMS=5000". A
    // template with no {server} token (like the local/dev default below) is used as-is.
    "ConnectionString": "mongodb://localhost:27017",
    // Database name prefix — used as "{DatabasePrefix}_{env}" for any environment that
    // doesn't set its own Mongo:DatabaseName in config/{env}.json.
    "DatabasePrefix": "BatchMonitor",
    "PerformanceTrackerCollection": "PerformanceTracker",
    // Domain/realm appended to the current Windows account name to build the Kerberos
    // (GSSAPI) principal used to authenticate — e.g. "user@CORP.EXAMPLE.COM". Leave blank
    // to disable Kerberos entirely and connect with no credential (local/dev Mongo with
    // no auth, like the default above).
    "KerberosDomain": "",
    "ConnectionTimeoutMs": 10000,
    "ServerSelectionTimeoutMs": 10000,
    "TlsEnabled": false,
    "TlsCertificatePath": "",
    "TlsCertificatePassword": ""
  },

  "Heartbeats": {
    // MongoDB collection name for heartbeat documents. This is the single source of truth
    // for the collection name — see MongoHeartbeatService.
    "CollectionName": "Heartbeats",
    // Expected interval (seconds) at which services write heartbeats.
    "IntervalSeconds": 15,
    // Seconds since a service's last heartbeat after which it's offline. 0 = IntervalSeconds * 2.
    "OfflineThresholdSeconds": 0,
    // Only services with a heartbeat within this many minutes are fetched from MongoDB.
    "RecentWindowMinutes": 30,
    // Minutes of inactivity (no subscribers) after which cached service data is released from memory.
    "IdleReleaseMinutes": 10
  },

  "Logs": {
    // Line-format templates the Log Browser's search and the LogViewer parser both use to
    // read log files consistently (so "caller:>", "thread:5" etc. filter the same way in both).
    "Formats": [
      "----- BEGIN {*}{newline}{timestamp}{newline}{level}|{host}|{pid}|{thread}|{message}|{caller}|{*}{newline}----- END {*}{newline}.{newline}",
      "{timestamp}|{level}|{host}|{pid}|{thread}|{message}|{caller}{*}{$}",
      "{timestamp}|{level}|{thread}|{message}|{caller}{*}{$}"
    ]
  },

  "FileBrowser": {
    // Ordered UNC templates for locating a service's log/metrics folder. Placeholders:
    // {server} {service} {pid} {env} {date} {date-1}. First template that resolves wins.
    "ServiceTemplates": [
      "C:\\Temp\\NxtUI-testlogs\\{date}\\Services\\{service}_{env}\\{server}_*_Pid_{pid}",
      "\\\\{server}\\Shared\\bau\\logs\\{date}\\Services\\{service}_{env}\\{server}_*_Pid_{pid}"
    ],
    // UNC template for the Log Browser's top-level "Root" node. Placeholder: {server}.
    "RootFolder": "C:\\Temp\\logs",
    //"RootFolder": "\\\\{server}\\Shared",
    // Path the Log Browser auto-navigates to on startup, relative to RootFolder. Supports {today}.
    "StartupFolder": "{today}",
    // How often (seconds) the Log Browser polls the selected folder and its parent.
    "FolderScanIntervalSeconds": 30,
    // "ServerOnly" (original behavior) | "ClientWithFallback" (try client-side File System
    // Access read first, fall back to server read on any failure) | "ClientOnly" (client-side
    // only, no fallback -- shows an error instead, useful for verifying it actually works
    // since ClientWithFallback's fallback can mask a broken client-side path).
    "FileAccessMode": "ServerOnly"
  },

  "Metrics": {
    // Per-environment Kafka topic services publish memory-metrics samples to. Tailed live;
    // falls back to on-disk logs only for history older than the topic's retention window.
    "TopicName": "metrics",
    // Fixed filename inside the folder resolved via FileBrowser:ServiceTemplates that holds
    // the memory-metrics lines.
    "FileName": "Metrics.log",
    // How often (seconds) to re-read the on-disk metrics file for new lines.
    "IntervalSeconds": 90,
    // "Both" (default: Kafka live + one-time disk backfill, falls back fully to disk if
    // an env's Kafka topic has no data) | "FileSystem" (disk only, no Kafka) | "Kafka"
    // (Kafka + its one-time disk backfill only, no ongoing file-tail polling).
    "Source": "Both",
    // Minutes of inactivity (no subscribers) after which cached metrics data (file offsets +
    // sample history) is released from memory.
    "IdleReleaseMinutes": 10
  },

  "Services": {
    // Filter text pre-populated in the Services page's filter box on load.
    "DefaultFilterText": "updated:>-30m"
  },

  "Runs": {
    // How often the home page polls for new runs, in seconds.
    "PollingIntervalSeconds": 30,
    // Default look-back window (months) for run history.
    "WindowMonths": 4,
    // Rows returned per query when the caller doesn't specify a count.
    "PageSize": 100,
    // Hard cap on rows returned per query, regardless of what the caller requests.
    "MaxResults": 1000,
    // Filter text pre-populated in the Runs page's filter box on load.
    "DefaultFilterText": "start:>=-10d",
    // Filter text pre-populated in the Run Stats page's filter box on load — shorter than
    // Runs' own default since Run Stats fans a request out to every selected environment.
    "RunStatsDefaultFilterText": "start:>=-24h",
    // "FixedSide" (default, fewer overlapping arrows) or "FixedPos" (arrows land
    // exactly on their pipeline row, but can overlap more in dense diagrams).
    "GraphPortConstraints": "FixedPos",
    // "Orthogonal" (default, H/V segments matching ELK's actual routing) or "Curved"
    // (smooth spline through the same waypoints). Applies to either port mode above.
    "GraphEdgeStyle": "Orthogonal",
    // Seconds since a pipeline's last finished chunk it still shows as "recently
    // active" (bright header/row color) in the run-detail flow graph. Raise this if
    // Replay's timestamp-truncated snapshots make too many pipelines look gray.
    "TopologyRecentActivityWindowSeconds": 15
  },

  "EnvConfig": {
    // Source-of-truth copy — read/edited on the Config page; backed up (timestamped)
    // just before every save. Expanded against the environment's first configured
    // server and the environment id. Placeholders: {server}, {env}.
    "SourcePathTemplate": "C:\\temp\\config\\settings.json",
    // Same file's path on every server in the environment (including the source
    // server) — overwritten on save, no backup taken here. Placeholders: {server}, {env}.
    "PathTemplate": "C:\\temp\\{server}\\settings.json",
    // Whether the Config page allows editing/saving at all. Default: false (read-only) --
    // this can write files on every server in an environment, so it's opt-in.
    "EditingEnabled": true,
    // "SingleLocation" (save only overwrites SourcePathTemplate, with a backup) |
    // "AllServers" (also mirrors to PathTemplate on every server, no backup on those).
    "SaveMode": "AllServers"
  },

  "InfraHealth": {
    // How often (seconds) the Home page's status strip pings each service.
    "KafkaPollIntervalSeconds": 30,
    "MongoPollIntervalSeconds": 30,
    // Max seconds a single Mongo ping may take before it's treated as a failure.
    "MongoPingTimeoutSeconds": 5,
    // Consecutive failed polls before status escalates from Degraded (yellow -- might just
    // be a blip) to Down (red -- consistently unreachable). A single isolated failure after
    // a run of successes always shows Degraded, never Down.
    "ConsecutiveFailuresBeforeDown": 3
  },

  "Diagnostics": {
    "Enabled": true
  },

  "TestLogGenerator": {
    "Enabled": false,
    "WriteIntervalSeconds": 15,
    "InitialLineCount": 5,
    "TemplateIndex": 0
  },

  "App": {
    "DefaultEnvironment": "DEV1",
    "DefaultPageSize": 25,
    "Environments": [
      {
        "Id": "DEV1",
        "Label": "Development 1",
        "Tier": "Development",
        "Servers": [ "dev1-srv-01", "dev1-srv-02" ]
      },
      {
        "Id": "DEV2",
        "Label": "Development 2",
        "Tier": "Development",
        "Servers": [ "dev2-srv-01" ]
      },
      {
        "Id": "UAT1",
        "Label": "UAT 1",
        "Tier": "UAT",
        "Servers": [ "uat1-srv-01", "uat1-srv-02" ]
      },
      {
        "Id": "UAT2",
        "Label": "UAT 2",
        "Tier": "UAT",
        "Servers": [ "uat2-srv-01" ]
      },
      {
        "Id": "STG1",
        "Label": "Staging 1",
        "Tier": "Staging",
        "Servers": [ "stg1-srv-01", "stg1-srv-02" ]
      },
      {
        "Id": "PROD1",
        "Label": "Production 1",
        "Tier": "Production",
        "Servers": [ "prod-srv-01", "prod-srv-02", "prod-srv-03" ]
      }
    ]
  }
}
