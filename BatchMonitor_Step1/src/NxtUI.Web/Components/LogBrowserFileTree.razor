@namespace NxtUI.Web.Components
@using NxtUI.Web.Models

@if (_servers.Count == 0)
{
    <div class="bm-lb-empty">
        <MudText Typo="Typo.body2" Class="bm-muted">No servers configured for this environment.</MudText>
        <MudText Typo="Typo.caption" Class="bm-muted">Add servers to App:Environments[].Servers in appsettings.</MudText>
    </div>
}
else if (LogsFolderMissing)
{
    <div class="bm-lb-empty">
        <MudText Typo="Typo.body2" Class="bm-muted">Logs:LogsFolder not configured.</MudText>
    </div>
}
else if (InitError is not null)
{
    <div class="bm-lb-empty">
        <MudText Typo="Typo.body2" Color="Color.Error">@InitError</MudText>
    </div>
}
else if (!Initialized)
{
    <div class="bm-lb-empty"><MudProgressCircular Indeterminate="true" Size="Size.Small" /></div>
}
else if (RootNodes.Count == 0)
{
    <div class="bm-lb-empty">
        <MudText Typo="Typo.body2" Class="bm-muted">No folders found.</MudText>
    </div>
}
else
{
    <MudTreeView T="LogFolderNode" Dense="true" Hover="true" Color="Color.Primary"
                 SelectedValueChanged="@((LogFolderNode? n) => OnTreeNodeSelected.InvokeAsync(n))"
                 Class="bm-lb-tree">
        @foreach (var node in RootNodes)
        {
            <MudTreeViewItem @key="@node.RelativePath" Value="@node" Text="@node.Name"
                             Icon="@(LoadingNodes.Contains(node.RelativePath) ? Icons.Material.Outlined.HourglassEmpty : Icons.Material.Outlined.Folder)"
                             Expanded="@Expanded.Contains(node.RelativePath)"
                             ExpandedChanged="@((bool exp) => OnExpandedChanged.InvokeAsync((node, exp)))"
                             OnClick="@((MouseEventArgs _) => OnItemClick.InvokeAsync(node))">
                @if (ChildCache.TryGetValue(node.RelativePath, out var ch1))
                {
                    @foreach (var c1 in ch1)
                    {
                        <MudTreeViewItem @key="@c1.RelativePath" Value="@c1" Text="@c1.Name"
                                         Icon="@(LoadingNodes.Contains(c1.RelativePath) ? Icons.Material.Outlined.HourglassEmpty : Icons.Material.Outlined.Folder)"
                                         Expanded="@Expanded.Contains(c1.RelativePath)"
                                         ExpandedChanged="@((bool exp) => OnExpandedChanged.InvokeAsync((c1, exp)))"
                                         OnClick="@((MouseEventArgs _) => OnItemClick.InvokeAsync(c1))">
                            @if (ChildCache.TryGetValue(c1.RelativePath, out var ch2))
                            {
                                @foreach (var c2 in ch2)
                                {
                                    <MudTreeViewItem @key="@c2.RelativePath" Value="@c2" Text="@c2.Name"
                                                     Icon="@(LoadingNodes.Contains(c2.RelativePath) ? Icons.Material.Outlined.HourglassEmpty : Icons.Material.Outlined.Folder)"
                                                     Expanded="@Expanded.Contains(c2.RelativePath)"
                                                     ExpandedChanged="@((bool exp) => OnExpandedChanged.InvokeAsync((c2, exp)))"
                                                     OnClick="@((MouseEventArgs _) => OnItemClick.InvokeAsync(c2))">
                                        @if (ChildCache.TryGetValue(c2.RelativePath, out var ch3))
                                        {
                                            @foreach (var c3 in ch3)
                                            {
                                                <MudTreeViewItem @key="@c3.RelativePath" Value="@c3" Text="@c3.Name"
                                                                 Icon="@Icons.Material.Outlined.Folder"
                                                                 OnClick="@((MouseEventArgs _) => OnItemClick.InvokeAsync(c3))" />
                                            }
                                        }
                                    </MudTreeViewItem>
                                }
                            }
                        </MudTreeViewItem>
                    }
                }
            </MudTreeViewItem>
        }
    </MudTreeView>
}

@code {
    [Parameter] public List<string>        Servers        { get; set; } = new();
    [Parameter] public List<LogFolderNode> RootNodes      { get; set; } = new();
    [Parameter] public Dictionary<string, IReadOnlyList<LogFolderNode>> ChildCache { get; set; } = new();
    [Parameter] public HashSet<string>     Expanded       { get; set; } = new();
    [Parameter] public HashSet<string>     LoadingNodes   { get; set; } = new();
    [Parameter] public bool                Initialized    { get; set; }
    [Parameter] public bool                LogsFolderMissing { get; set; }
    [Parameter] public string?             InitError      { get; set; }

    [Parameter] public EventCallback<LogFolderNode?>          OnTreeNodeSelected { get; set; }
    [Parameter] public EventCallback<(LogFolderNode, bool)>   OnExpandedChanged  { get; set; }
    [Parameter] public EventCallback<LogFolderNode>           OnItemClick        { get; set; }

    // Expose the server count for the parent's empty-state check
    private List<string> _servers => Servers;
}
