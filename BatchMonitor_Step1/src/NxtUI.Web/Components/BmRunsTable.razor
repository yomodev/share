@namespace NxtUI.Web.Components
@using NxtUI.Core.Models
@using NxtUI.Web.Services
@inject DateTimeDisplayService DtSvc

<div class="bm-table-wrap">
    @if (Loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="bm-loading-bar" />
    }
    <MudTable T="RunSummary"
              Items="@Rows"
              Dense="true"
              Hover="true"
              Elevation="0"
              Striped="true"
              Class="bm-batch-table"
              FixedHeader="@FixedHeader"
              Height="@(FixedHeader ? "100%" : null)"
              RowClassFunc="@RowClassFunc">
        <HeaderContent>
            <MudTh Style="width:36px;"></MudTh>
            <MudTh>@HeaderContent("Run ID", "RunId")</MudTh>
            <MudTh>@HeaderContent("Description", "Description")</MudTh>
            <MudTh>@HeaderContent("Type", "Type")</MudTh>
            <MudTh>@HeaderContent("Started (UTC)", "StartTime")</MudTh>
            <MudTh>Duration</MudTh>
            <MudTh>@HeaderContent("Status", "Status")</MudTh>
            @if (ShowActions)
            {
                <MudTh Style="width:110px; text-align:center;">Actions</MudTh>
            }
        </HeaderContent>
        <RowTemplate>
            <MudTd Style="padding-left:12px;"
                   @onclick="@(() => OnRowClick.InvokeAsync(context))"
                   @ondblclick="@(() => OnOpenDetail.InvokeAsync(context))">
                <StatusIcon Status="@context.Status" />
            </MudTd>
            <MudTd @onclick="@(() => OnRowClick.InvokeAsync(context))"
                   @ondblclick="@(() => OnOpenDetail.InvokeAsync(context))">
                <MudText Typo="Typo.body2" Class="bm-monospace bm-muted">@context.RunId</MudText>
            </MudTd>
            <MudTd @onclick="@(() => OnRowClick.InvokeAsync(context))"
                   @ondblclick="@(() => OnOpenDetail.InvokeAsync(context))">
                <MudText Typo="Typo.body2">@context.Description</MudText>
            </MudTd>
            <MudTd @onclick="@(() => OnRowClick.InvokeAsync(context))"
                   @ondblclick="@(() => OnOpenDetail.InvokeAsync(context))">
                <MudChip T="string" Size="Size.Small" Class="bm-type-chip">@context.Type</MudChip>
            </MudTd>
            <MudTd @onclick="@(() => OnRowClick.InvokeAsync(context))"
                   @ondblclick="@(() => OnOpenDetail.InvokeAsync(context))">
                <MudText Typo="Typo.body2" Class="bm-monospace bm-muted">
                    @DtSvc.Format(context.Start, "yyyy-MM-dd HH:mm:ss")
                </MudText>
            </MudTd>
            <MudTd @onclick="@(() => OnRowClick.InvokeAsync(context))"
                   @ondblclick="@(() => OnOpenDetail.InvokeAsync(context))">
                <MudText Typo="Typo.body2" Class="bm-monospace">
                    @FormatDuration(context.Duration)
                </MudText>
            </MudTd>
            <MudTd @onclick="@(() => OnRowClick.InvokeAsync(context))"
                   @ondblclick="@(() => OnOpenDetail.InvokeAsync(context))">
                <span class="bm-status-text bm-status-@context.Status.ToString().ToLower()">
                    @context.Status
                </span>
            </MudTd>
            @if (ShowActions)
            {
                <MudTd Style="text-align:center;">
                    <div class="bm-row-actions">
                        <MudTooltip Text="Open Detail">
                            <MudIconButton Icon="@Icons.Material.Outlined.OpenInNew"
                                           Size="Size.Small"
                                           OnClick="@(() => OnOpenDetail.InvokeAsync(context))" />
                        </MudTooltip>
                        <MudTooltip Text="Open Timeline">
                            <MudIconButton Icon="@Icons.Material.Outlined.Timeline"
                                           Size="Size.Small"
                                           OnClick="@(() => OnOpenTimeline.InvokeAsync(context))" />
                        </MudTooltip>
                        <MudTooltip Text="@(context.Status == RunStatus.Running ? "Stop Run" : "Not running")">
                            <span>
                                <MudIconButton Icon="@Icons.Material.Outlined.StopCircle"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               Disabled="@(context.Status != RunStatus.Running)"
                                               OnClick="@(() => OnStopRun.InvokeAsync(context))" />
                            </span>
                        </MudTooltip>
                    </div>
                </MudTd>
            }
        </RowTemplate>
    </MudTable>
</div>

@if (ShowPaginationAndFilter && ShowFooter)
{
    <div class="bm-batch-footer">
        <MudText Typo="Typo.body2" Class="bm-muted bm-footer-count">
            @TotalCount results
        </MudText>

        <BmPagination Count="@TotalPages"
                      Selected="@Page"
                      SelectedChanged="@(p => PageChanged.InvokeAsync(p))" />

        <div class="bm-rows-select">
            <MudText Typo="Typo.body2" Class="bm-muted" Style="white-space:nowrap;">Rows:</MudText>
            <MudSelect T="int"
                       Value="@PageSize"
                       ValueChanged="@(sz => PageSizeChanged.InvokeAsync(sz))"
                       Dense="true"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Style="width:90px">
                <MudSelectItem Value="10">10</MudSelectItem>
                <MudSelectItem Value="25">25</MudSelectItem>
                <MudSelectItem Value="50">50</MudSelectItem>
                <MudSelectItem Value="100">100</MudSelectItem>
                <MudSelectItem Value="200">200</MudSelectItem>
            </MudSelect>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public List<RunSummary> Rows { get; set; } = new();
    [Parameter] public bool Loading { get; set; }
    [Parameter] public bool FixedHeader { get; set; } = true;

    // When false, the Actions column (open detail / timeline / stop) is omitted —
    // used by pickers like the Timeline "Add Run" dialog where rows are selected,
    // not acted on directly.
    [Parameter] public bool ShowActions { get; set; } = true;

    // Row-level single-click selection (distinct from the per-cell OnOpenDetail
    // double-click), and a per-row CSS class hook for highlighting the selection.
    [Parameter] public EventCallback<RunSummary> OnRowClick { get; set; }
    [Parameter] public Func<RunSummary, int, string>? RowClassFunc { get; set; }

    // When false (Home's "recent runs" use case), no footer/pagination is shown
    // and no header sort links are wired — just the same columns/actions as
    // the full Runs page, with whatever rows the caller already fetched.
    [Parameter] public bool ShowPaginationAndFilter { get; set; } = true;

    // When false, the internal pagination/rows-per-page footer is suppressed while
    // sorting (ShowPaginationAndFilter) still works — used when the caller wants to
    // render pagination itself elsewhere (e.g. the Timeline "Add Run" dialog puts it
    // in the dialog's action bar instead of under the table).
    [Parameter] public bool ShowFooter { get; set; } = true;

    [Parameter] public int TotalCount { get; set; }
    [Parameter] public int Page { get; set; } = 1;
    [Parameter] public int PageSize { get; set; } = 25;
    [Parameter] public int TotalPages { get; set; } = 1;
    [Parameter] public EventCallback<int> PageChanged { get; set; }
    [Parameter] public EventCallback<int> PageSizeChanged { get; set; }

    // Server-side sort state — only meaningful when ShowPaginationAndFilter is true.
    [Parameter] public string? SortField { get; set; }
    [Parameter] public bool SortDescending { get; set; }
    [Parameter] public EventCallback<string> OnSort { get; set; }

    [Parameter, EditorRequired] public EventCallback<RunSummary> OnOpenDetail { get; set; }
    [Parameter] public EventCallback<RunSummary> OnOpenTimeline { get; set; }
    [Parameter] public EventCallback<RunSummary> OnStopRun { get; set; }

    private RenderFragment HeaderContent(string label, string field)
    {
        if (!ShowPaginationAndFilter || !OnSort.HasDelegate)
        {
            return @<text>@label</text>;
        }

        return @<MudLink Underline="Underline.Hover"
                 Color="Color.Inherit"
                 OnClick="@(() => OnSort.InvokeAsync(field))"
                 Style="cursor:pointer; display:inline-flex; align-items:center; gap:2px;">
            @label
            @if (SortField == field)
            {
                <MudIcon Icon="@(SortDescending ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)"
                          Size="Size.Small" />
            }
        </MudLink>;
    }

    private static string FormatDuration(TimeSpan ts) =>
        ts.TotalHours >= 1
            ? $"{(int)ts.TotalHours:D2}:{ts.Minutes:D2}:{ts.Seconds:D2}"
            : $"{ts.Minutes:D2}:{ts.Seconds:D2}";
}
