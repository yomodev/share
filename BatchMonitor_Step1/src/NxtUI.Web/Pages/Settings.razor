@implements IAsyncDisposable
@inject ThemeService ThemeService
@inject IJSRuntime JS
@using Microsoft.JSInterop

<div class="bm-settings-page">

    <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight:600;">
        <MudIcon Icon="@Icons.Material.Outlined.Settings" Class="mr-2" Size="Size.Small" />
        Settings
    </MudText>

    <MudGrid Spacing="4">

        <MudItem xs="12" md="6">
            <MudPaper Elevation="0" Class="bm-settings-section">
                <MudText Typo="Typo.subtitle2" Class="bm-section-title mb-4">Appearance</MudText>
                <div class="bm-settings-row">
                    <div>
                        <MudText Typo="Typo.body1">Theme</MudText>
                        <MudText Typo="Typo.body2" Class="bm-muted">
                            Choose dark, light, or follow your OS setting
                        </MudText>
                    </div>
                    <div class="bm-theme-switcher">
                        <span class="@(_mode == ThemeMode.Dark ? "bm-theme-btn-active" : "")">
                            <MudToggleIconButton Toggled="@(_mode == ThemeMode.Dark)"
                                                 Icon="@Icons.Material.Outlined.DarkMode"
                                                 ToggledIcon="@Icons.Material.Filled.DarkMode"
                                                 ToggledColor="Color.Primary"
                                                 Size="Size.Medium"
                                                 Title="Dark"
                                                 ToggledChanged="@(v => { if (v) SetMode(ThemeMode.Dark); })" />
                        </span>
                        <span class="@(_mode == ThemeMode.Light ? "bm-theme-btn-active" : "")">
                            <MudToggleIconButton Toggled="@(_mode == ThemeMode.Light)"
                                                 Icon="@Icons.Material.Outlined.LightMode"
                                                 ToggledIcon="@Icons.Material.Filled.LightMode"
                                                 ToggledColor="Color.Primary"
                                                 Size="Size.Medium"
                                                 Title="Light"
                                                 ToggledChanged="@(v => { if (v) SetMode(ThemeMode.Light); })" />
                        </span>
                        <span class="@(_mode == ThemeMode.System ? "bm-theme-btn-active" : "")">
                            <MudToggleIconButton Toggled="@(_mode == ThemeMode.System)"
                                                 Icon="@Icons.Material.Outlined.SettingsBrightness"
                                                 ToggledIcon="@Icons.Material.Filled.SettingsBrightness"
                                                 ToggledColor="Color.Primary"
                                                 Size="Size.Medium"
                                                 Title="System"
                                                 ToggledChanged="@(v => { if (v) SetMode(ThemeMode.System); })" />
                        </span>
                    </div>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Elevation="0" Class="bm-settings-section">
                <MudText Typo="Typo.subtitle2" Class="bm-section-title mb-4">About</MudText>
                <div class="bm-about-grid">
                    <MudText Typo="Typo.body2" Class="bm-muted">Version</MudText>
                    <MudText Typo="Typo.body2" Class="bm-monospace">0.6.22.1</MudText>
                    <MudText Typo="Typo.body2" Class="bm-muted">Framework</MudText>
                    <MudText Typo="Typo.body2" Class="bm-monospace">.NET 8 / Blazor Server</MudText>
                    <MudText Typo="Typo.body2" Class="bm-muted">UI Library</MudText>
                    <MudText Typo="Typo.body2" Class="bm-monospace">MudBlazor 9.5</MudText>
                </div>
            </MudPaper>
        </MudItem>

    </MudGrid>
</div>

@code {
    private ThemeMode _mode;
    private IJSObjectReference? _appModule;

    protected override void OnInitialized()
    {
        _mode = ThemeService.Mode;
        ThemeService.OnChange += OnThemeExternallyChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _appModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/app.js?v=4");
    }

    private void SetMode(ThemeMode mode)
    {
        _mode = mode;
        ThemeService.Mode = mode;
        var cookie = mode switch
        {
            ThemeMode.Light  => "light",
            ThemeMode.System => "system",
            _                => "dark",
        };
        _ = _appModule?.InvokeVoidAsync("saveTheme", cookie);
    }

    private void OnThemeExternallyChanged()
    {
        _mode = ThemeService.Mode;
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        ThemeService.OnChange -= OnThemeExternallyChanged;
        if (_appModule is not null)
        {
            try { await _appModule.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }
    }
}
