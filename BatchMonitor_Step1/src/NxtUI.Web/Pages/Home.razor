@namespace NxtUI.Pages
@using NxtUI.Core.Models
@using NxtUI.Core.Services
@inject EnvironmentSelectorService EnvService
@inject TabService TabService
@inject IRunService RunService
@inject InfraHealthCache HealthCache
@implements IDisposable

<div class="bm-home">

    <!-- ── Header ────────────────────────────────────────────────────────── -->
    <div class="bm-home-header">
        <div>
            <MudText Typo="Typo.h5" Class="bm-home-title">System dashboard</MudText>
            <MudText Typo="Typo.body2" Class="bm-home-subtitle">
                Real-time system monitor
            </MudText>
        </div>
        <div class="bm-home-env">
            <MudSelect T="string"
                       Value="@EnvService.SelectedId"
                       ValueChanged="OnEnvChanged"
                       Dense="true"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Class="bm-home-env-select">
                @foreach (var env in EnvService.Environments)
                {
                    <MudSelectItem Value="@env.Id">
                        <div class="bm-env-option">
                            <span class="bm-env-badge"
                                  style="background:@env.BadgeColor; color:@env.BadgeTextColor">
                                @env.Id
                            </span>
                            <span class="bm-env-label">@env.Label</span>
                        </div>
                    </MudSelectItem>
                }
            </MudSelect>
        </div>
    </div>

    <!-- ── Memory treemap ──────────────────────────────────────────────────── -->
    <div style="display:flex;flex-direction:column;gap:6px;">
        <div class="bm-section-header">
            <MudText Typo="Typo.subtitle2" Class="bm-section-title">Memory</MudText>
            <span class="bm-muted" style="font-size:12px;">online services only · click to open services</span>
        </div>
        <HomeMemoryTreemap Env="@EnvService.SelectedId" />
    </div>

    <!-- ── Infrastructure health ─────────────────────────────────────────── -->
    <div class="bm-section-header">
        <MudText Typo="Typo.subtitle2" Class="bm-section-title">Infrastructure Health</MudText>
        <span class="bm-muted" style="font-size:12px;">auto-refresh every 10 s</span>
    </div>

    <div class="bm-infra-grid">

        <!-- Kafka card -->
        <div class="bm-health-card bm-health-@StatusCss(_kafkaHealth?.Status)">
            <div class="bm-health-card-header">
                <MudIcon Icon="@Icons.Material.Outlined.Stream" Size="Size.Small" Class="bm-health-svc-icon" />
                <span class="bm-health-name">Kafka</span>
                @if (_kafkaChecking)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="bm-health-spinner" />
                }
                else if (_kafkaHealth is not null)
                {
                    <span class="bm-health-pill bm-health-pill-@StatusCss(_kafkaHealth.Status)">
                        @_kafkaHealth.Status.ToString().ToUpper()
                    </span>
                }
                <span class="bm-health-time bm-muted">
                    @(_kafkaHealth?.CheckedAt.ToString("HH:mm:ss") ?? "--:--:--") UTC
                </span>
            </div>

            <div class="bm-health-nodes">
                @if (_kafkaHealth is not null)
                {
                    @foreach (var b in _kafkaHealth.Brokers)
                    {
                        <div class="bm-health-node">
                            <span class="bm-health-dot @(b.IsOnline ? "bm-dot-ok" : "bm-dot-err")"></span>
                            <span class="bm-health-host">@b.Host:@b.Port</span>
                            @if (b.IsOnline && b.LatencyMs.HasValue)
                            {
                                <span class="bm-health-latency">@b.LatencyMs ms</span>
                            }
                            else if (!b.IsOnline)
                            {
                                <span class="bm-health-offline">offline</span>
                            }
                            <span class="bm-health-role bm-muted">broker @b.Id</span>
                        </div>
                    }
                }
                else
                {
                    <div class="bm-health-node bm-muted" style="justify-content:center; padding:16px 0;">
                        Connecting…
                    </div>
                }
            </div>

            @if (_kafkaHealth is not null)
            {
                var onlineKafka = _kafkaHealth.Brokers.Count(b => b.IsOnline);
                var totalKafka  = _kafkaHealth.Brokers.Count;
                <div class="bm-health-footer">
                    <span>@onlineKafka / @totalKafka brokers online</span>
                    @if (_kafkaHealth.Error is not null)
                    {
                        <span class="bm-health-err-text">@_kafkaHealth.Error</span>
                    }
                </div>
            }
        </div>

        <!-- MongoDB card -->
        <div class="bm-health-card bm-health-@StatusCss(_mongoHealth?.Status)">
            <div class="bm-health-card-header">
                <MudIcon Icon="@Icons.Material.Outlined.Storage" Size="Size.Small" Class="bm-health-svc-icon" />
                <span class="bm-health-name">MongoDB</span>
                @if (_mongoChecking)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="bm-health-spinner" />
                }
                else if (_mongoHealth is not null)
                {
                    <span class="bm-health-pill bm-health-pill-@StatusCss(_mongoHealth.Status)">
                        @_mongoHealth.Status.ToString().ToUpper()
                    </span>
                }
                <span class="bm-health-time bm-muted">
                    @(_mongoHealth?.CheckedAt.ToString("HH:mm:ss") ?? "--:--:--") UTC
                </span>
            </div>

            <div class="bm-health-nodes">
                @if (_mongoHealth is not null)
                {
                    @foreach (var n in _mongoHealth.Nodes)
                    {
                        <div class="bm-health-node">
                            <span class="bm-health-dot @(n.IsOnline ? "bm-dot-ok" : "bm-dot-err")"></span>
                            <span class="bm-health-host">@n.Host</span>
                            @if (n.IsOnline && n.LatencyMs.HasValue)
                            {
                                <span class="bm-health-latency">@n.LatencyMs ms</span>
                            }
                            else if (!n.IsOnline)
                            {
                                <span class="bm-health-offline">offline</span>
                            }
                            <span class="bm-health-role @(n.Role == "PRIMARY" ? "bm-health-role-primary" : "bm-muted")">
                                @n.Role
                            </span>
                        </div>
                    }
                }
                else
                {
                    <div class="bm-health-node bm-muted" style="justify-content:center; padding:16px 0;">
                        Connecting…
                    </div>
                }
            </div>

            @if (_mongoHealth is not null)
            {
                <div class="bm-health-footer">
                    <span>@_mongoHealth.DatabaseCount databases · replica set</span>
                    @if (_mongoHealth.Error is not null)
                    {
                        <span class="bm-health-err-text">@_mongoHealth.Error</span>
                    }
                </div>
            }
        </div>

    </div>

    <!-- ── Mini batch summary ─────────────────────────────────────────────── -->
    <MudPaper Elevation="0" Class="bm-mini-summary">
        <div class="bm-mini-summary-header">
            <MudText Typo="Typo.subtitle2" Class="bm-section-title">Recent Runs</MudText>
            <MudButton Variant="Variant.Text" Size="Size.Small"
                       StartIcon="@Icons.Material.Outlined.ViewList"
                       OnClick="OpenRunsDashboard"
                       Class="bm-view-all-btn">
                View All
            </MudButton>
        </div>

        <MudTable T="RunSummary"
                  Items="@_recent"
                  Dense="true"
                  Hover="true"
                  Elevation="0"
                  Class="bm-mini-table">
            <HeaderContent>
                <MudTh Style="width:36px;"></MudTh>
                <MudTh>Name</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Started</MudTh>
                <MudTh>Duration</MudTh>
                <MudTh Style="width:80px;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd><StatusIcon Status="@context.Status" /></MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2">@context.Name</MudText>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Class="bm-type-chip">@context.Type</MudChip>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Class="bm-monospace bm-muted">
                        @context.Start.ToString("HH:mm:ss") UTC
                    </MudText>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Class="bm-monospace bm-muted">
                        @FormatDuration(context.Duration)
                    </MudText>
                </MudTd>
                <MudTd Style="text-align:right;">
                    <MudTooltip Text="Open Detail">
                        <MudIconButton Icon="@Icons.Material.Outlined.OpenInNew"
                                       Size="Size.Small"
                                       OnClick="@(() => OpenDetail(context))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

</div>

@code {
    // Batch state
    private List<RunSummary> _recent = new();

    // Health state
    private KafkaHealth? _kafkaHealth   = null;
    private MongoHealth? _mongoHealth   = null;
    private bool         _kafkaChecking = false;
    private bool         _mongoChecking = false;

    private CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        EnvService.OnChange     += OnEnvExternalChange;
        HealthCache.OnHealthUpdated += OnHealthUpdated;
        await Task.WhenAll(LoadRunsAsync(), CheckHealthAsync());
    }

    // ── Batch ─────────────────────────────────────────────────────────────

    private async Task LoadRunsAsync()
    {
        try
        {
            var batches = await RunService.GetRunsAsync(EnvService.SelectedId, DateTime.UtcNow, 5);
            _recent = batches.Take(5).ToList();
        }
        catch { /* non-critical */ }
    }

    // ── Health ────────────────────────────────────────────────────────────

    private async Task CheckHealthAsync()
    {
        var env = EnvService.SelectedId;
        _kafkaHealth   = HealthCache.GetKafka(env);
        _mongoHealth   = HealthCache.GetMongo(env);
        _kafkaChecking = false;
        _mongoChecking = false;
        await InvokeAsync(StateHasChanged);
        // Request a background refresh; OnHealthUpdated will trigger StateHasChanged when done.
        HealthCache.RequestRefresh(env);
    }

    private async void OnHealthUpdated(string env)
    {
        if (env != EnvService.SelectedId) return;
        await CheckHealthAsync();
    }

    // ── Env change ────────────────────────────────────────────────────────

    private async void OnEnvExternalChange()
    {
        _recent = [];
        await InvokeAsync(StateHasChanged);
        await Task.WhenAll(LoadRunsAsync(), CheckHealthAsync());
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnEnvChanged(string newId)
    {
        EnvService.SelectedId = newId;
        _recent = [];
        await Task.WhenAll(LoadRunsAsync(), CheckHealthAsync());
    }

    // ── Navigation ────────────────────────────────────────────────────────

    private void OpenRunsDashboard() =>
        TabService.OpenOrFocus(TabModel.CreateRunsDashboard(EnvService.SelectedId));

    private void OpenDetail(RunSummary b) =>
        TabService.OpenOrFocus(TabModel.CreateRunDetail(b.RunId, b.Name, EnvService.SelectedId));

    // ── Helpers ───────────────────────────────────────────────────────────

    private static string StatusCss(HealthStatus? s) => s switch
    {
        HealthStatus.Healthy  => "healthy",
        HealthStatus.Degraded => "degraded",
        HealthStatus.Down     => "down",
        HealthStatus.Checking => "checking",
        _                     => "unknown",
    };

    private static string FormatDuration(TimeSpan ts) =>
        ts.TotalHours >= 1
            ? $"{(int)ts.TotalHours:D2}:{ts.Minutes:D2}:{ts.Seconds:D2}"
            : $"{ts.Minutes:D2}:{ts.Seconds:D2}";

    public void Dispose()
    {
        EnvService.OnChange         -= OnEnvExternalChange;
        HealthCache.OnHealthUpdated -= OnHealthUpdated;
        _cts.Cancel();
    }
}
