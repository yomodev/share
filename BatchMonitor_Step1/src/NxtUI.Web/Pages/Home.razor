@namespace NxtUI.Web.Pages
@using Microsoft.Extensions.Options
@using NxtUI.Configuration
@using NxtUI.Core.Models
@using NxtUI.Core.Services
@inject EnvironmentSelectorService EnvService
@inject TabService TabService
@inject IRunService RunService
@inject InfraHealthCache HealthCache
@inject ILogger<Home> Logger
@inject DateTimeDisplayService DtSvc
@inject IOptions<RunsSettings> RunsOpts
@inject ISnackbar Snackbar
@implements IDisposable

<div class="bm-home">

    <!-- ── Header ────────────────────────────────────────────────────────── -->
    <div class="bm-home-header">

        <div class="bm-home-header-left">
            <!-- Env selector (left of title) -->
            <MudMenu AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft" Dense="true" PopoverClass="bm-env-menu-popover">
                <ActivatorContent>
                    <span class="bm-env-badge bm-env-badge-btn bm-env-badge-home"
                          style="background:@(EnvService.Selected?.BadgeColor); color:@(EnvService.Selected?.BadgeTextColor)"
                          @onclick="@(async e => await context.ToggleAsync(e))">
                        @EnvService.SelectedId
                    </span>
                </ActivatorContent>
                <ChildContent>
                    @foreach (var env in EnvService.Environments)
                    {
                        var envId = env.Id;
                        <MudMenuItem OnClick="@(async () => await OnEnvChanged(envId))">
                            <div class="bm-env-menu-item">
                                <span class="bm-env-badge"
                                      style="background:@env.BadgeColor; color:@env.BadgeTextColor">
                                    @env.Id
                                </span>
                                <span class="bm-env-label">@env.Label</span>
                            </div>
                        </MudMenuItem>
                    }
                </ChildContent>
            </MudMenu>

            <div class="bm-home-title-block">
                <MudText Typo="Typo.h5" Class="bm-home-title">System dashboard</MudText>
                <MudText Typo="Typo.body2" Class="bm-home-subtitle">
                    Real-time system monitor
                </MudText>
            </div>
        </div>

        <!-- Infra health strip (right) -->
        <div class="bm-infra-strip">

            <!-- Kafka -->
            <div class="bm-infra-svc">
                <MudIcon Icon="@Icons.Material.Outlined.Stream" Class="bm-infra-svc-icon" />
                <span class="bm-infra-svc-name">Kafka</span>
                <div class="bm-infra-dots">
                    @if (_kafkaHealth is null)
                    {
                        <span class="bm-infra-dot bm-infra-dot-unknown bm-infra-dot-pulse"></span>
                    }
                    else
                    {
                        @foreach (var b in _kafkaHealth.Brokers)
                        {
                            var bLabel = $"broker {b.Id} · {b.Host}:{b.Port} · {(b.IsOnline ? (b.LatencyMs.HasValue ? $"{b.LatencyMs} ms" : "online") : "offline")}";
                            <MudTooltip Text="@bLabel" Placement="Placement.Bottom" Arrow="true">
                                <span class="bm-infra-dot @(b.IsOnline ? "bm-infra-dot-ok" : "bm-infra-dot-err")"></span>
                            </MudTooltip>
                        }
                    }
                </div>
                <span class="bm-infra-label bm-infra-label-@StatusCss(_kafkaHealth?.Status)">
                    @(_kafkaHealth?.Status.ToString().ToUpper() ?? "…")
                </span>
            </div>

            <div class="bm-infra-sep"></div>

            <!-- Mongo -->
            <div class="bm-infra-svc">
                <MudIcon Icon="@Icons.Material.Outlined.Storage" Class="bm-infra-svc-icon" />
                <span class="bm-infra-svc-name">Mongo</span>
                <div class="bm-infra-dots">
                    @if (_mongoHealth is null)
                    {
                        <span class="bm-infra-dot bm-infra-dot-unknown bm-infra-dot-pulse"></span>
                    }
                    else if (_mongoHealth.Nodes.Count == 0)
                    {
                        var singleTip = _mongoHealth.Status == HealthStatus.Healthy ? "ping ok" : (_mongoHealth.Error ?? "down");
                        <MudTooltip Text="@singleTip" Placement="Placement.Bottom" Arrow="true">
                            <span class="bm-infra-dot @(_mongoHealth.Status == HealthStatus.Healthy ? "bm-infra-dot-ok" : "bm-infra-dot-err")"></span>
                        </MudTooltip>
                    }
                    else
                    {
                        @foreach (var n in _mongoHealth.Nodes)
                        {
                            var nLabel = $"{n.Host} · {n.Role} · {(n.IsOnline ? (n.LatencyMs.HasValue ? $"{n.LatencyMs} ms" : "online") : "offline")}";
                            <MudTooltip Text="@nLabel" Placement="Placement.Bottom" Arrow="true">
                                <span class="bm-infra-dot @(n.IsOnline ? "bm-infra-dot-ok" : "bm-infra-dot-err")
                                    @(n.Role == "PRIMARY" ? " bm-infra-dot-primary" : "")"></span>
                            </MudTooltip>
                        }
                    }
                </div>
                <span class="bm-infra-label bm-infra-label-@StatusCss(_mongoHealth?.Status)">
                    @(_mongoHealth?.Status.ToString().ToUpper() ?? "…")
                </span>
            </div>

            <div class="bm-infra-sep"></div>

            <MudTooltip Text="@($"last checked {(_kafkaHealth is not null ? DtSvc.Format(_kafkaHealth.CheckedAt, "HH:mm:ss") : "--:--:--")}{DtSvc.ZoneSuffix}")" Placement="Placement.Bottom">
                <div class="bm-infra-lastupdate">
                    <span class="bm-infra-lastupdate-label bm-muted">Last update</span>
                    <span class="bm-infra-time bm-muted">@(_kafkaHealth is not null ? DtSvc.Format(_kafkaHealth.CheckedAt, "HH:mm") : "--:--")</span>
                </div>
            </MudTooltip>

        </div>

    </div>

    <!-- ── Memory treemap ────────────────────────────────────────────────── -->
    <div class="bm-section-header" style="margin:0;">
        <div class="bm-memory-header-left bm-section-title-link" @onclick="OpenServices" title="View all services">
            @if (!_mapReady)
            {
                <div class="bm-section-spinner"></div>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Outlined.Dns" Class="bm-memory-header-icon" />
            }
            <MudText Typo="Typo.subtitle2" Class="bm-section-title">Memory</MudText>
        </div>
    </div>
    <HomeMemoryTreemap Env="@EnvService.SelectedId" Visible="@IsVisible"
                        OnFirstPaint="OnMapDataLoaded" OnPidClicked="OnTreemapPidClicked" />

    <!-- ── Mini batch summary ───────────────────────────────────────────── -->
    <div class="bm-section-header" style="margin:4px 0 0;">
        <div class="bm-memory-header-left bm-section-title-link" @onclick="OpenRunsDashboard" title="View more runs">
            @if (!_runsReady || _runsLoading)
            {
                <div class="bm-section-spinner"></div>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Outlined.ViewList" Class="bm-memory-header-icon" />
            }
            <MudText Typo="Typo.subtitle2" Class="bm-section-title">Recent Runs</MudText>
        </div>
    </div>

    <MudPaper Elevation="0" Class="bm-mini-summary">
        <BmRunsTable Rows="@_recent"
                     Loading="@_runsLoading"
                     FixedHeader="false"
                     ShowPaginationAndFilter="false"
                     OnOpenDetail="@(r => OpenDetail(r))"
                     OnOpenTimeline="@(r => OpenTimeline(r))"
                     OnStopRun="@(r => StopRunAsync(r))" />
    </MudPaper>

</div>

@code {
    // Batch state
    private List<RunSummary> _recent = new();

    // Health state
    private KafkaHealth? _kafkaHealth = null;
    private MongoHealth? _mongoHealth = null;

    private CancellationTokenSource _cts = new();

    // Controls the Runs polling loop's lifetime independently of _cts — started
    // only while Home is visible, cancelled the moment it isn't, so no polling
    // happens in the background while a tab is focused.
    private CancellationTokenSource? _pollCts;

    // Home is visible only when no tab is active. Track the previous state so
    // we can trigger a data refresh when the user switches back to Home.
    private bool _wasVisible;

    // Each section shows a small spinner in its header (left of the label) until it
    // has loaded once, then swaps to the section icon — never re-blanks on later
    // visibility toggles. _runsLoading additionally flips the spinner back on during
    // every poll tick, since a Recent Runs refresh actually swaps the rendered rows.
    private bool _mapReady;
    private bool _runsReady;
    private bool _runsLoading;

    protected override async Task OnInitializedAsync()
    {
        EnvService.OnChange         += OnEnvExternalChange;
        HealthCache.OnHealthUpdated += OnHealthUpdated;
        TabService.OnChange         += OnTabVisibilityChanged;
        _wasVisible = TabService.ActiveTab is null;
        HealthCache.RequestRefresh(EnvService.SelectedId);
        await Task.WhenAll(LoadRunsAsync(), CheckHealthAsync());
        _runsReady = true;
        if (IsVisible) StartPolling();
    }

    private void OnMapDataLoaded() => _ = InvokeAsync(() => { _mapReady = true; StateHasChanged(); });

    private bool IsVisible => TabService.ActiveTab is null;

    private void StartPolling()
    {
        if (_pollCts is not null) return; // already running
        _pollCts = new CancellationTokenSource();
        _ = PollRunsAsync(_pollCts.Token);
    }

    private void StopPolling()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollCts = null;
    }

    private void OnTabVisibilityChanged()
    {
        var visible = IsVisible;
        if (visible && !_wasVisible)
        {
            // Home just became visible — refresh stale data, render, then resume polling.
            StartPolling();
            _ = InvokeAsync(async () =>
            {
                try
                {
                    HealthCache.RequestRefresh(EnvService.SelectedId);
                    await Task.WhenAll(LoadRunsAsync(), CheckHealthAsync());
                    StateHasChanged();
                }
                catch (Exception ex) { Logger.LogError(ex, "Home visibility refresh failed"); }
            });
        }
        else if (!visible && _wasVisible)
        {
            // Home just became hidden — stop polling entirely, not just the render.
            StopPolling();
        }
        _wasVisible = visible;
    }

    // ── Batch ─────────────────────────────────────────────────────────────

    private async Task LoadRunsAsync()
    {
        _runsLoading = true;
        try
        {
            _recent = await RunService.GetRunsAsync(
                EnvService.SelectedId, DateTime.UtcNow, 10, ct: _cts.Token);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { Logger.LogError(ex, "LoadRunsAsync failed"); }
        finally { _runsLoading = false; }
    }

    private async Task PollRunsAsync(CancellationToken ct)
    {
        var interval = TimeSpan.FromSeconds(RunsOpts.Value.PollingIntervalSeconds);
        while (!ct.IsCancellationRequested)
        {
            try
            {
                await Task.Delay(interval, ct);
                await LoadRunsAsync();
                await InvokeAsync(StateHasChanged);
            }
            catch (OperationCanceledException) { break; }
            catch (Exception ex) { Logger.LogError(ex, "Runs polling failed"); }
        }
    }

    // ── Health ────────────────────────────────────────────────────────────

    private async Task CheckHealthAsync()
    {
        var env = EnvService.SelectedId;
        _kafkaHealth = HealthCache.GetKafka(env);
        _mongoHealth = HealthCache.GetMongo(env);
        await InvokeAsync(() => { if (IsVisible) StateHasChanged(); });
    }

    private void OnHealthUpdated(string env)
    {
        if (env != EnvService.SelectedId) return;
        _ = InvokeAsync(async () =>
        {
            try { await CheckHealthAsync(); }
            catch (Exception ex) { Logger.LogError(ex, "Health update failed"); }
        });
    }

    // ── Env change ────────────────────────────────────────────────────────

    private void OnEnvExternalChange()
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                _recent       = [];
                _runsReady    = false;
                _mapReady     = false; // new env's treemap has no cached paint yet
                if (IsVisible) StateHasChanged();
                HealthCache.RequestRefresh(EnvService.SelectedId);
                await Task.WhenAll(LoadRunsAsync(), CheckHealthAsync());
                _runsReady = true;
                if (IsVisible) StateHasChanged();
            }
            catch (Exception ex) { Logger.LogError(ex, "Env change update failed"); }
        });
    }

    private async Task OnEnvChanged(string newId)
    {
        EnvService.SelectedId = newId;
        _recent               = [];
        _runsReady            = false;
        _mapReady             = false;
        HealthCache.RequestRefresh(newId);
        await Task.WhenAll(LoadRunsAsync(), CheckHealthAsync());
        _runsReady = true;
    }

    // ── Navigation ────────────────────────────────────────────────────────

    private void OpenRunsDashboard() =>
        TabService.OpenOrFocus(TabModel.CreateRunsDashboard(EnvService.SelectedId));

    private void OpenServices() =>
        TabService.OpenOrFocus(TabModel.CreateServicesDashboard(EnvService.SelectedId));


    private void OnTreemapPidClicked(string key)
    {
        var tab = TabModel.CreateMemoryGraph(EnvService.SelectedId);
        tab.NavigationHint = key;
        TabService.OpenOrFocus(tab);
    }

    private void OpenDetail(RunSummary b) =>
        TabService.OpenOrFocus(TabModel.CreateRunDetail(b.RunId, b.RunId, EnvService.SelectedId));

    private void OpenTimeline(RunSummary b) =>
        TabService.OpenOrFocus(TabModel.CreateTimeline(b.RunId, EnvService.SelectedId));

    private async Task StopRunAsync(RunSummary b)
    {
        var ok = await RunService.CancelRunAsync(EnvService.SelectedId, b.RunId, _cts.Token);
        if (ok)
        {
            Snackbar.Add($"Stop requested for {b.RunId}", Severity.Warning);
            await LoadRunsAsync();
        }
        else
            Snackbar.Add("Could not stop run", Severity.Error);
    }

    // ── Helpers ───────────────────────────────────────────────────────────

    private static string StatusCss(HealthStatus? s) => s switch
    {
        HealthStatus.Healthy  => "healthy",
        HealthStatus.Degraded => "degraded",
        HealthStatus.Down     => "down",
        HealthStatus.Checking => "checking",
        _                     => "unknown",
    };

    public void Dispose()
    {
        EnvService.OnChange         -= OnEnvExternalChange;
        HealthCache.OnHealthUpdated -= OnHealthUpdated;
        TabService.OnChange         -= OnTabVisibilityChanged;
        StopPolling();
        _cts.Cancel();
    }
}
