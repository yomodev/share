@namespace NxtUI.Web.Pages
@using NxtUI.Web.Models
@inject IRunService RunService
@inject SignalRConnectionService SignalR
@inject IJSRuntime JS
@implements IAsyncDisposable

@code {
    [Parameter, EditorRequired] public TabModel? Tab { get; set; }
    [Parameter, EditorRequired] public string Environment { get; set; } = string.Empty;
    [Parameter] public string? InitialRunId { get; set; }
    [Parameter] public bool IsFocused { get; set; }

    // ── Batch data ────────────────────────────────────────────────────────
    private readonly List<TimelineRun> _runs = new();
    private readonly SemaphoreSlim _runLock = new(1, 1);

    // ── Filter ────────────────────────────────────────────────────────────
    private string _filterText = string.Empty;

    private static readonly (string Aliases, string Label)[] _timelineFieldHints =
    [
        ("svc / service",   "service name"),
        ("pipe / pipeline", "pipeline name"),
        ("src / source",    "source identifier"),
        ("chunk / chunkId", "chunk ID"),
        ("srv / server",    "server / host"),
        ("pid / processId", "process ID"),
        ("dur / duration",  "event duration  (hh:mm or hh:mm:ss)"),
        ("start",           "event start time (UTC)"),
        ("finish",          "event finish time (UTC)"),
    ];

    // ── Control bar state ─────────────────────────────────────────────────
    private GroupByOption _groupBy = GroupByOption.ServicePipeline;
    private ColourByOption _colourBy = ColourByOption.Source;
    private bool _stackView   = false;
    private bool _showTooltip = true;

    // ── Shortcuts dialog ──────────────────────────────────────────────────
    private bool _shortcutsOpen = false;

    // ── Add Batch dialog ──────────────────────────────────────────────────
    private bool _addDialogOpen = false;
    private List<RunSummary> _dialogBatches = new();
    private RunSummary? _dialogSelected;
    private string _dialogFilter = string.Empty;
    private string _dialogEnv = string.Empty;
    private bool _dialogLoading = false;
    private int _dialogPage = 1;
    private const int DialogPageSize = 25;

    // ── JS interop ────────────────────────────────────────────────────────
    private string _instanceKey = Guid.NewGuid().ToString("N");
    private ElementReference _canvasRef;
    private ElementReference _bottomRef;
    private ElementReference _importWrapRef;
    private IJSObjectReference? _tlModule;
    private IJSObjectReference? _appModule;
    private CancellationTokenSource? _renderDebounce;
    private const int RenderDebounceMs = 300;

    // Set by control-bar handlers so OnAfterRenderAsync pushes data to JS
    // AFTER Blazor finishes the render.
    private bool _pendingJsPush = false;

    // ── Lifecycle ─────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _dialogEnv = Environment;

        if (!string.IsNullOrEmpty(InitialRunId))
        {
            await LoadRunsAsync(Environment, InitialRunId);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_tlModule is not null)
            await _tlModule.InvokeVoidAsync("setVisible", _instanceKey, IsFocused);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _appModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/app.js?v=5");
                _tlModule  = await JS.InvokeAsync<IJSObjectReference>("import", "./js/d3-timeline.js?v=6");
                await _tlModule.InvokeVoidAsync("init", _instanceKey, _canvasRef, _bottomRef, GetOptions());
                await PushDataAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[Timeline] JS init error: {ex.Message}");
            }
        }
        else if (_pendingJsPush && _tlModule is not null)
        {
            // Push runs here — AFTER Blazor has committed the render batch (including
            // MudBlazor's popover close). This prevents the double-batch race that
            // causes "Cannot read properties of null (reading 'removeChild')".
            _pendingJsPush = false;
            await PushDataAsync();
        }
    }

    protected override bool ShouldRender() => IsFocused || _tlModule is null;

    // ── Batch loading ─────────────────────────────────────────────────────

    private async Task LoadRunsAsync(string env, string runId)
    {
        await _runLock.WaitAsync();
        try
        {
            var existing = _runs.FirstOrDefault(b => b.RunId == runId && b.Env == env);
            if (existing is not null)
            {
                // Already loaded — refresh/merge events.
                await existing.RefreshAsync(RunService);
            }
            else
            {
                var batch = new TimelineRun(env, runId, RunService, SignalR,
                    onUpdated: async () => await DebouncedPushAsync());
                await batch.LoadAsync();
                _runs.Add(batch);
            }
        }
        finally { _runLock.Release(); }

        await DebouncedPushAsync();
        StateHasChanged();
    }

    private async Task RemoveAsync(string runId, string env)
    {
        await _runLock.WaitAsync();
        try
        {
            var batch = _runs.FirstOrDefault(b => b.RunId == runId && b.Env == env);
            if (batch is not null)
            {
                await batch.DisposeAsync();
                _runs.Remove(batch);
            }
        }
        finally { _runLock.Release(); }

        await DebouncedPushAsync();
        StateHasChanged();
    }

    private async Task RemoveAllAsync()
    {
        await _runLock.WaitAsync();
        try
        {
            foreach (var b in _runs) await b.DisposeAsync();
            _runs.Clear();
        }
        finally { _runLock.Release(); }

        await DebouncedPushAsync();
        StateHasChanged();
    }

    // ── D3 data push ─────────────────────────────────────────────────────

    private async Task DebouncedPushAsync()
    {
        _renderDebounce?.Cancel();
        _renderDebounce?.Dispose();
        _renderDebounce = new CancellationTokenSource();
        var token = _renderDebounce.Token;

        try
        {
            await Task.Delay(RenderDebounceMs, token);
            if (!token.IsCancellationRequested)
                await InvokeAsync(PushDataAsync);
        }
        catch (OperationCanceledException) { }
    }

    private async Task PushDataAsync()
    {
        if (_tlModule is null) return;
        try
        {
            var payload = BuildPayload();
            await _tlModule.InvokeVoidAsync("update", _instanceKey, payload);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Timeline] Push error: {ex.Message}");
        }
    }

    private object BuildPayload()
    {
        return new
        {
            groupBy   = _groupBy.ToString(),
            colourBy  = _colourBy.ToString(),
            stackView = _stackView,
            filter    = _filterText,
            batches   = _runs.Select(b => new
            {
                runId             = b.RunId,
                env               = b.Env,
                batchName         = b.Name,
                isLive            = b.IsLive,
                batchStartEpochMs = new DateTimeOffset(b.RunStart).ToUnixTimeMilliseconds(),
                events    = b.Events.Select(e => new
                {
                    chunkId   = e.ChunkId,
                    source    = e.Source,
                    pipeline  = e.Pipeline,
                    service   = e.Service,
                    processId = e.ProcessId,
                    server    = e.Server,
                    startMs  = (e.Start - b.RunStart).TotalMilliseconds,
                    finishMs = e.Finish.HasValue ? (e.Finish.Value - b.RunStart).TotalMilliseconds : (double?)null,
                    error    = e.Error,
                    status      = e.IsError ? "error" : e.IsDone ? "done" : "inprogress",
                }).ToList(),
            }).ToList(),
        };
    }

    private object GetOptions() => new
    {
        groupBy  = _groupBy.ToString(),
        colourBy = _colourBy.ToString(),
    };

    // ── Control bar handlers ──────────────────────────────────────────────

    private void OnGroupByChanged(GroupByOption v)
    {
        _groupBy = v;
        _pendingJsPush = true;
    }

    private void OnColourByChanged(ColourByOption v)
    {
        _colourBy = v;
        _pendingJsPush = true;
    }

    private void OnFilterChanged(string v)
    {
        _filterText = v;
        _ = InvokeAsync(PushDataAsync);
    }

    private void ToggleStackView()
    {
        _stackView = !_stackView;
        _pendingJsPush = true;
    }

    private async Task ToggleTooltipAsync()
    {
        _showTooltip = !_showTooltip;
        if (_tlModule is not null)
            await _tlModule.InvokeVoidAsync("setTooltipVisible", _instanceKey, _showTooltip);
    }

    private async Task ResetView()
    {
        if (_tlModule is null) return;
        await _tlModule.InvokeVoidAsync("resetView", _instanceKey);
        await PushDataAsync();
    }

    private void ExportCsv()
    {
        if (_tlModule is not null)
            _ = _tlModule.InvokeVoidAsync("exportCsv", _instanceKey);
    }

    private async Task TriggerImport()
    {
        if (_appModule is not null)
            await _appModule.InvokeVoidAsync("clickInputInside", _importWrapRef);
    }

    private async Task OnImportFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10 MB max
            using var reader = new System.IO.StreamReader(stream);
            var csv = await reader.ReadToEndAsync();
            await ImportCsvAsync(csv);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Timeline] Import error: {ex.Message}");
        }
    }

    /// <summary>
    /// Parses a timeline CSV export and upserts events into existing or new
    /// TimelineRun instances, grouped by RunId (§10 import spec).
    /// </summary>
    private async Task ImportCsvAsync(string csv)
    {
        if (string.IsNullOrWhiteSpace(csv)) return;

        var lines = csv.Split('\n', StringSplitOptions.RemoveEmptyEntries);
        if (lines.Length < 2) return;

        // Parse header to find column indices.
        var header = ParseCsvLine(lines[0]);
        int idx(string name) => Array.FindIndex(header, h => h.Equals(name, StringComparison.OrdinalIgnoreCase));

        var iRunId    = idx("RunId");
        var iChunkId  = idx("ChunkId");
        var iSource   = idx("Source");
        var iPipeline = idx("Pipeline");
        var iService  = idx("Service");
        var iPid      = idx("PID");
        var iServer   = idx("Server");
        var iStart    = idx("Start");
        var iFinish   = idx("Finish");
        var iError    = idx("Error");

        if (iRunId < 0 || iChunkId < 0) return; // unrecognised format

        // Group rows by RunId.
        var byRunId = new Dictionary<string, List<PerformanceEvent>>();

        foreach (var line in lines.Skip(1))
        {
            var cols = ParseCsvLine(line);
            if (cols.Length <= Math.Max(iRunId, iChunkId)) continue;

            var runId = cols[iRunId];
            if (string.IsNullOrEmpty(runId)) continue;

            if (!byRunId.TryGetValue(runId, out var evts))
                byRunId[runId] = evts = new List<PerformanceEvent>();

            string Col(int i) => i >= 0 && i < cols.Length ? cols[i] : string.Empty;

            DateTime? ParseDt(string raw) =>
                DateTime.TryParse(raw, null, System.Globalization.DateTimeStyles.RoundtripKind, out var dt)
                    ? dt : null;

            var startDt  = ParseDt(Col(iStart))  ?? DateTime.UtcNow;
            var finishDt = ParseDt(Col(iFinish));

            evts.Add(new PerformanceEvent
            {
                ChunkId   = Col(iChunkId),
                Source    = Col(iSource),
                Pipeline  = Col(iPipeline),
                Service   = Col(iService),
                ProcessId = Col(iPid),
                Server    = Col(iServer),
                Start     = startDt,
                Finish    = finishDt,
                Error     = string.IsNullOrEmpty(Col(iError)) ? null : Col(iError),
            });
        }

        // Upsert into existing or new batches.
        foreach (var (runId, events) in byRunId)
        {
            await _runLock.WaitAsync();
            try
            {
                var existing = _runs.FirstOrDefault(b => b.RunId == runId);
                if (existing is not null)
                {
                    // Merge into existing batch.
                    foreach (var e in events)
                        existing.UpsertEventPublic(e);
                }
                else
                {
                    // Create a CSV-only batch (no live subscription, no polling).
                    var batch = TimelineRun.CreateFromCsv(runId, Environment, events);
                    _runs.Add(batch);
                }
            }
            finally { _runLock.Release(); }
        }

        await PushDataAsync();
        StateHasChanged();
    }

    private static string[] ParseCsvLine(string line)
    {
        // Simple CSV parser — handles quoted fields with embedded commas/quotes.
        var result = new List<string>();
        bool inQuote = false;
        var current = new System.Text.StringBuilder();
        foreach (char c in line.TrimEnd('\r'))
        {
            if (c == '"') { inQuote = !inQuote; }
            else if (c == ',' && !inQuote) { result.Add(current.ToString()); current.Clear(); }
            else current.Append(c);
        }
        result.Add(current.ToString());
        return result.ToArray();
    }

    // ── Add Batch dialog ──────────────────────────────────────────────────

    private async Task OpenAddDialog()
    {
        _addDialogOpen    = true;
        _dialogSelected   = null;
        _dialogFilter     = string.Empty;
        _dialogPage       = 1;
        await LoadDialogAsync();
    }

    private async Task LoadDialogAsync()
    {
        _dialogLoading = true;
        StateHasChanged();
        try
        {
            var filter = new RunFilter { SearchText = _dialogFilter };
            var page   = await RunService.GetRunsAsync(
                _dialogEnv, DateTime.UtcNow, DialogPageSize * _dialogPage, filter);
            // Poor man's pagination: fetch N items and skip to page.
            _dialogBatches = page
                .Skip((_dialogPage - 1) * DialogPageSize)
                .Take(DialogPageSize)
                .ToList();
        }
        finally { _dialogLoading = false; StateHasChanged(); }
    }

    private async Task OnDialogEnvChanged(string env)
    {
        _dialogEnv      = env;
        _dialogPage     = 1;
        _dialogSelected = null;
        await LoadDialogAsync();
    }

    private async Task OnDialogFilterChanged(string text)
    {
        _dialogFilter   = text;
        _dialogPage     = 1;
        _dialogSelected = null;
        await LoadDialogAsync();
    }

    private async Task ConfirmAdd()
    {
        if (_dialogSelected is null) return;
        _addDialogOpen = false;
        await LoadRunsAsync(_dialogEnv, _dialogSelected.RunId);
        // Push immediately regardless of pause state — user explicitly added a batch.
        await PushDataAsync();
    }

    // ── Dialog row click / double-click ───────────────────────────────────
    // MouseEventArgs.Detail = click count: 1 = single, 2 = double.
    private async Task OnDialogRowClick(RunSummary item, MouseEventArgs mouse)
    {
        if (mouse.Detail == 2)
        {
            _dialogSelected = item;
            await ConfirmAdd();
        }
        else
        {
            _dialogSelected = _dialogSelected?.RunId == item.RunId ? null : item;
        }
    }

    private bool IsAlreadyLoaded(RunSummary b) =>
        _runs.Any(x => x.RunId == b.RunId && x.Env == _dialogEnv);

    // ── Dispose ───────────────────────────────────────────────────────────

    public async ValueTask DisposeAsync()
    {
        _renderDebounce?.Cancel();
        _renderDebounce?.Dispose();

        await _runLock.WaitAsync();
        try { foreach (var b in _runs) await b.DisposeAsync(); }
        finally { _runLock.Release(); }

        if (_tlModule is not null)
        {
            try { await _tlModule.InvokeVoidAsync("dispose", _instanceKey); }
            catch (Exception) { }
            try { await _tlModule.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }
        if (_appModule is not null)
        {
            try { await _appModule.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }
    }

    // ── Enums ─────────────────────────────────────────────────────────────

    public enum GroupByOption
    {
        ServicePipeline,
        PidServicePipeline,
        Service,
        Pipeline,
        Pid,
    }

    public enum ColourByOption
    {
        Source,
        Pipeline,
        Service,
        Status,
    }
}

<!-- ── Markup ──────────────────────────────────────────────────────────── -->
<div class="bm-page-fill bm-timeline">

    <!-- Control bar -->
    <div class="bm-tl-controls">
        <div class="bm-tl-controls-left">
            <MudTooltip Text="@(_stackView ? "Exit stack view" : "Stack view")">
                <MudIconButton Icon="@Icons.Material.Outlined.ViewColumn"
                               Color="@(_stackView ? Color.Primary : Color.Default)"
                               Size="Size.Small" OnClick="ToggleStackView" />
            </MudTooltip>

            <FilterBox Value="@_filterText"
                       OnFilterChanged="OnFilterChanged"
                       DebounceMs="250"
                       Class="bm-tl-filter"
                       FieldHints="@_timelineFieldHints" />

            <div class="bm-tl-select-wrap">
                <span class="bm-toolbar-label">Group</span>
                <MudSelect T="GroupByOption" Value="_groupBy" ValueChanged="OnGroupByChanged"
                           Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                           Disabled="_stackView" Class="bm-tl-select"
                           PopoverClass="bm-tl-select-popover">
                    <MudSelectItem Value="GroupByOption.ServicePipeline">Service / Pipeline</MudSelectItem>
                    <MudSelectItem Value="GroupByOption.PidServicePipeline">Service / Pipeline / PID</MudSelectItem>
                    <MudSelectItem Value="GroupByOption.Service">Service</MudSelectItem>
                    <MudSelectItem Value="GroupByOption.Pipeline">Pipeline</MudSelectItem>
                    <MudSelectItem Value="GroupByOption.Pid">PID</MudSelectItem>
                </MudSelect>
            </div>

            <div class="bm-tl-select-wrap">
                <span class="bm-toolbar-label">Color</span>
                <MudSelect T="ColourByOption" Value="_colourBy" ValueChanged="OnColourByChanged"
                           Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                           Disabled="_stackView" Class="bm-tl-select"
                           PopoverClass="bm-tl-select-popover">
                    <MudSelectItem Value="ColourByOption.Source">Source</MudSelectItem>
                    <MudSelectItem Value="ColourByOption.Pipeline">Pipeline</MudSelectItem>
                    <MudSelectItem Value="ColourByOption.Service">Service</MudSelectItem>
                    <MudSelectItem Value="ColourByOption.Status">Status</MudSelectItem>
                </MudSelect>
            </div>
        </div>

        <div class="bm-tl-controls-right">
            <MudTooltip Text="@(_showTooltip ? "Hide message popup" : "Show message popup")">
                <MudIconButton Icon="@(_showTooltip ? Icons.Material.Outlined.SpeakerNotes : Icons.Material.Outlined.SpeakerNotesOff)"
                               Color="@(_showTooltip ? Color.Default : Color.Primary)"
                               Size="Size.Small" OnClick="ToggleTooltipAsync" />
            </MudTooltip>

            <MudTooltip Text="Reset view">
                <MudIconButton Icon="@Icons.Material.Outlined.ZoomOutMap"
                               Size="Size.Small" OnClick="ResetView" />
            </MudTooltip>

            <MudTooltip Text="Keyboard shortcuts">
                <MudIconButton Icon="@Icons.Material.Outlined.Keyboard"
                               Size="Size.Small" OnClick="@(() => _shortcutsOpen = true)" />
            </MudTooltip>

            <MudTooltip Text="Export CSV">
                <MudIconButton Icon="@Icons.Material.Outlined.Save"
                               Size="Size.Small" OnClick="ExportCsv" />
            </MudTooltip>

            <MudTooltip Text="Import CSV">
                <MudIconButton Icon="@Icons.Material.Outlined.FolderOpen"
                               Size="Size.Small" OnClick="TriggerImport" />
            </MudTooltip>

            <span @ref="_importWrapRef" style="display:none">
                <InputFile OnChange="OnImportFileSelected" accept=".csv" />
            </span>

            <MudTooltip Text="Remove from view">
                <span>
                    <MudMenu Icon="@Icons.Material.Outlined.LayersClear" Size="Size.Small"
                             Dense="true" Disabled="@(!_runs.Any())"
                             AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        @foreach (var b in _runs)
                        {
                            var runId = b.RunId;
                            var env   = b.Env;
                            <MudMenuItem OnClick="@(() => RemoveAsync(runId, env))">
                                @b.Name <span class="bm-muted">@b.RunId</span>
                            </MudMenuItem>
                        }
                        <MudDivider />
                        <MudMenuItem OnClick="RemoveAllAsync">
                            <MudText Color="Color.Error">Remove all</MudText>
                        </MudMenuItem>
                    </MudMenu>
                </span>
            </MudTooltip>

            <MudButton StartIcon="@Icons.Material.Outlined.Add"
                       Variant="Variant.Outlined" Size="Size.Small"
                       Class="ml-2"
                       OnClick="OpenAddDialog">
                Add
            </MudButton>
        </div>
    </div>

    <!-- D3 canvas — scrollable lane area. No Blazor children inside; child list
         must not change after init because D3 owns the SVG inside _canvasRef. -->
    <div class="bm-tl-canvas-wrap" style="position:relative">
        <div class="bm-tl-canvas" @ref="_canvasRef"></div>
    </div>

    @if (!_runs.Any())
    {
        <div class="bm-tl-empty">
            <MudIcon Icon="@Icons.Material.Outlined.Timeline" Style="font-size:3rem; opacity:0.25" />
            <div class="bm-muted" style="margin-top:8px">No batches loaded — click <strong>Add</strong> to begin</div>
        </div>
    }

    <!-- Fixed bottom panel: global tick scale + range selector brush.
         Always visible, never scrolls. D3 appends its own SVG here. -->
    <div class="bm-tl-bottom-panel" @ref="_bottomRef"></div>

    <!-- Shortcuts dialog -->
    <MudDialog @bind-Visible="_shortcutsOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true })">
        <TitleContent>
            <MudText Typo="Typo.h6">Keyboard Shortcuts</MudText>
        </TitleContent>
        <DialogContent>
            <MudSimpleTable Dense="true" Hover="false" Bordered="false" Striped="false" Class="bm-tl-shortcuts-table">
                <thead>
                    <tr>
                        <th>Shortcut</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td><kbd>←</kbd> / <kbd>→</kbd></td><td>Pan timeline left / right</td></tr>
                    <tr><td><kbd>Ctrl</kbd>+<kbd>←</kbd></td><td>Zoom out (toward cursor)</td></tr>
                    <tr><td><kbd>Ctrl</kbd>+<kbd>→</kbd></td><td>Zoom in (toward cursor)</td></tr>
                    <tr><td><kbd>Ctrl</kbd>+<kbd>↑</kbd></td><td>Decrease bar height</td></tr>
                    <tr><td><kbd>Ctrl</kbd>+<kbd>↓</kbd></td><td>Increase bar height</td></tr>
                    <tr><td>Wheel on selector</td><td>Zoom in / out toward mouse</td></tr>
                    <tr><td>↑ / ↓</td><td>Scroll lanes up / down</td></tr>
                    <tr><td><kbd>Ctrl</kbd>+click block</td><td>Copy message details to clipboard</td></tr>
                </tbody>
            </MudSimpleTable>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _shortcutsOpen = false)">Close</MudButton>
        </DialogActions>
    </MudDialog>

    <!-- Add Batch dialog -->
    <MudDialog @bind-Visible="_addDialogOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true })">
        <TitleContent>
            <MudText Typo="Typo.h6">Add Batch</MudText>
        </TitleContent>
        <DialogContent>
            <div class="bm-tl-dialog-controls">
                <MudSelect T="string" Label="Environment" Value="_dialogEnv"
                           ValueChanged="OnDialogEnvChanged"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Class="bm-tl-dialog-env">
                    @* environments populated from EnvironmentSelectorService in a real impl *@
                    <MudSelectItem Value="@Environment">@Environment</MudSelectItem>
                </MudSelect>

                <MudTextField T="string" Placeholder="Search RunId / Name…"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Outlined.Search"
                              Value="@_dialogFilter" ValueChanged="OnDialogFilterChanged"
                              Immediate="true" DebounceInterval="300"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Class="bm-tl-dialog-filter" />
            </div>

            @if (_dialogLoading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            else
            {
                <MudDataGrid T="RunSummary" Items="@_dialogBatches"
                             RowClick="@(async e => await OnDialogRowClick(e.Item, e.MouseEventArgs))"
                             RowClassFunc="@((row, _) => _dialogSelected?.RunId == row.RunId ? "bm-tl-dialog-selected" : "")"
                             Dense="true" Hover="true" Striped="true" Bordered="false">
                    <Columns>
                        <PropertyColumn Property="x => x.RunId" Title="RunId" />
                        <PropertyColumn Property="x => x.Name" Title="Name" />
                        <TemplateColumn Title="Status">
                            <CellTemplate>
                                <StatusIcon Status="@context.Item.Status" />
                            </CellTemplate>
                        </TemplateColumn>
                        <PropertyColumn Property="x => x.Start" Title="Start" Format="HH:mm" />
                        <TemplateColumn Title="Duration">
                            <CellTemplate>
                                @(context.Item.End.HasValue
                                    ? FormatDuration(context.Item.End.Value - context.Item.Start)
                                    : "—")
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                </MudDataGrid>
            }

            @if (_dialogSelected is not null && IsAlreadyLoaded(_dialogSelected))
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                    Already loaded: @_dialogSelected.RunId (@_dialogEnv) — loading will refresh/merge events.
                </MudAlert>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _addDialogOpen = false)">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       Disabled="@(_dialogSelected is null)"
                       OnClick="ConfirmAdd">
                Load Batch
            </MudButton>
        </DialogActions>
    </MudDialog>
</div>

@code {
    private static string FormatDuration(TimeSpan ts) =>
        ts.TotalHours >= 1
            ? $"{(int)ts.TotalHours}h {ts.Minutes:D2}m"
            : $"{ts.Minutes}m {ts.Seconds:D2}s";
}
