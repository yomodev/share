@namespace NxtUI.Web.Pages
@inject IRunService RunService
@inject TabService TabService
@inject ISnackbar Snackbar
@inject DateTimeDisplayService DtSvc
@inject Microsoft.Extensions.Options.IOptions<NxtUI.Configuration.RunsSettings> RunsOptions
@using NxtUI.Filtering
@implements IDisposable

<div class="bm-page bm-page-fill">

    <!-- ── Toolbar: filter + refresh ────────────────────────────────── -->
    <div class="bm-batch-toolbar">
        <FilterBox Value="@_filterText"
                   OnFilterChanged="OnFilterChanged"
                   ParseError="@_filterParseError"
                   Placeholder="Filter runs…"
                   Class="bm-filter-input"
                   FieldHints="@_runFieldHints" />

        <MudTooltip Text="Refresh">
            <MudIconButton Icon="@Icons.Material.Outlined.Refresh"
                           Size="Size.Small"
                           OnClick="RefreshAsync"
                           Disabled="@_result.IsLoading"
                           Class="bm-refresh-btn" />
        </MudTooltip>
    </div>

    <!-- ── Table ─────────────────────────────────────────────────────── -->
    <div class="bm-table-wrap">
        @if (_result.IsFailed)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="bm-data-error ma-2">@_result.Error</MudAlert>
        }
        <!-- Table shell (headers, toolbar, pagination) renders immediately; only
             the rows populate progressively. Loading="" shows MudTable's own
             progress bar without hiding the structure underneath. -->
        <MudTable T="RunSummary"
                  Items="@_paged"
                  Loading="@_result.IsLoading"
                  LoadingProgressColor="Color.Primary"
                  Dense="true"
                  Hover="true"
                  Elevation="0"
                  Striped="true"
                  Class="bm-batch-table"
                  FixedHeader="true"
                  Height="100%">
            <HeaderContent>
                <MudTh Style="width:36px;"></MudTh>
                <MudTh>@SortableHeader("Run ID", "RunId")</MudTh>
                <MudTh>@SortableHeader("Description", "Description")</MudTh>
                <MudTh>@SortableHeader("Type", "Type")</MudTh>
                <MudTh>@SortableHeader("Started (UTC)", "StartTime")</MudTh>
                <MudTh>Duration</MudTh>
                <MudTh>@SortableHeader("Status", "Status")</MudTh>
                <MudTh Style="width:110px; text-align:center;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="padding-left:12px;" @ondblclick="@(() => OpenDetail(context))">
                    <StatusIcon Status="@context.Status" />
                </MudTd>
                <MudTd @ondblclick="@(() => OpenDetail(context))">
                    <MudText Typo="Typo.body2" Class="bm-monospace bm-muted">@context.RunId</MudText>
                </MudTd>
                <MudTd @ondblclick="@(() => OpenDetail(context))">
                    <MudText Typo="Typo.body2">@context.Description</MudText>
                </MudTd>
                <MudTd @ondblclick="@(() => OpenDetail(context))">
                    <MudChip T="string" Size="Size.Small" Class="bm-type-chip">@context.Type</MudChip>
                </MudTd>
                <MudTd @ondblclick="@(() => OpenDetail(context))">
                    <MudText Typo="Typo.body2" Class="bm-monospace bm-muted">
                        @DtSvc.Format(context.Start, "yyyy-MM-dd HH:mm:ss")
                    </MudText>
                </MudTd>
                <MudTd @ondblclick="@(() => OpenDetail(context))">
                    <MudText Typo="Typo.body2" Class="bm-monospace">
                        @FormatDuration(context.Duration)
                    </MudText>
                </MudTd>
                <MudTd @ondblclick="@(() => OpenDetail(context))">
                    <span class="bm-status-text bm-status-@context.Status.ToString().ToLower()">
                        @context.Status
                    </span>
                </MudTd>
                <MudTd Style="text-align:center;">
                    <div class="bm-row-actions">
                        <MudTooltip Text="Open Detail">
                            <MudIconButton Icon="@Icons.Material.Outlined.OpenInNew"
                                           Size="Size.Small"
                                           OnClick="@(() => OpenDetail(context))" />
                        </MudTooltip>
                        <MudTooltip Text="Open Timeline">
                            <MudIconButton Icon="@Icons.Material.Outlined.Timeline"
                                           Size="Size.Small"
                                           OnClick="@(() => OpenTimeline(context))" />
                        </MudTooltip>
                        <MudTooltip Text="@(context.Status == RunStatus.Running ? "Stop Run" : "Not running")">
                            <span>
                                <MudIconButton Icon="@Icons.Material.Outlined.StopCircle"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               Disabled="@(context.Status != RunStatus.Running)"
                                               OnClick="@(() => StopRunAsync(context))" />
                            </span>
                        </MudTooltip>
                    </div>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </div>

    <!-- ── Footer: count + rows per page + pagination ────────────────── -->
    <div class="bm-batch-footer">
        <MudText Typo="Typo.body2" Class="bm-muted bm-footer-count">
            @_all.Count results
        </MudText>

        <BmPagination Count="@_totalPages"
                      Selected="@_page"
                      SelectedChanged="OnPageChanged" />

        <div class="bm-rows-select">
            <MudText Typo="Typo.body2" Class="bm-muted" Style="white-space:nowrap;">Rows:</MudText>
            <MudSelect T="int"
                       Value="@_pageSize"
                       ValueChanged="OnPageSizeChanged"
                       Dense="true"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Style="width:90px">
                <MudSelectItem Value="10">10</MudSelectItem>
                <MudSelectItem Value="25">25</MudSelectItem>
                <MudSelectItem Value="50">50</MudSelectItem>
                <MudSelectItem Value="100">100</MudSelectItem>
                <MudSelectItem Value="200">200</MudSelectItem>
                <MudSelectItem Value="100">100</MudSelectItem>
            </MudSelect>
        </div>
    </div>

</div>

@code {
    [Parameter, EditorRequired] public string Environment { get; set; } = string.Empty;
    [Parameter] public TabModel? Tab { get; set; }

    private int _page     = 1;
    private int _pageSize = 25;
    private Result<List<RunSummary>> _result;

    // Default filter: last 10 days — the query always runs server-side, so this
    // is the first WHERE clause SQL sees, not a client-side post-filter.
    private const string DefaultFilterText = "start:>=-10d";

    private string      _filterText       = DefaultFilterText;
    private string?     _filterParseError = null;
    private FilterNode? _filterAst        = null;

    private static readonly string[] RunSearchableFields = ["RunId", "Description", "Type", "Status"];
    private static readonly FilterParser RunFilterParser   = new(RunSearchableFields);

    private static readonly (string Aliases, string Label)[] _runFieldHints =
    [
        ("run / runid",                 "run identifier"),
        ("requestid / reqid",           "request identifier (int)"),
        ("type",                        "run type"),
        ("status",                      "Running / Completed / Failed"),
        ("start / started",             "start time"),
        ("end / ended / finish",        "end time"),
        ("desc / description",          "description"),
    ];

    private List<RunSummary> _all   = new();
    private List<RunSummary> _paged = new();
    private int _totalPages => Math.Max(1, (int)Math.Ceiling((double)_all.Count / _pageSize));

    // Server-side sort — every column click re-queries, same as filter changes.
    private string _sortField      = "StartTime";
    private bool   _sortDescending = true;

    private CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        ParseFilterText(DefaultFilterText);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _result = default; // loading
        Tab?.BeginLoading();
        TabService.NotifyChanged();
        StateHasChanged();
        try
        {
            _all = await RunService.GetRunsAsync(
                Environment, DateTime.UtcNow, RunsOptions.Value.MaxResults,
                filter: new RunFilter
                {
                    FilterAst      = _filterAst,
                    SortField      = _sortField,
                    SortDescending = _sortDescending,
                },
                ct: _cts.Token);
            _page = 1;
            RebuildPage();
            _result = Result<List<RunSummary>>.Ok(_all);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _result = Result<List<RunSummary>>.Fail(ex.Message);
        }
        finally
        {
            Tab?.EndLoading();
            TabService.NotifyChanged();
        }
    }

    private void ParseFilterText(string text)
    {
        _filterText = text;
        _filterParseError = null;

        FilterNode? node = null;
        if (!string.IsNullOrWhiteSpace(text))
        {
            try   { node = RunFilterParser.Parse(text, DtSvc.UseUtc); }
            catch (FilterParseException ex) { _filterParseError = ex.Message; }
        }

        _filterAst = node;
    }

    // Every filter change re-queries the server — SQL applies the WHERE clause,
    // never a client-side re-filter of an already-fetched page.
    private async Task OnFilterChanged(string text)
    {
        ParseFilterText(text);
        if (_filterParseError is not null) { StateHasChanged(); return; }
        await LoadAsync();
    }

    // Clicking a column header re-queries the server with the new sort — same
    // principle as filtering: the client never re-orders an already-fetched page.
    private async Task OnSort(string field)
    {
        if (_sortField == field) _sortDescending = !_sortDescending;
        else { _sortField = field; _sortDescending = true; }
        await LoadAsync();
    }

    private RenderFragment SortableHeader(string label, string field) => @<MudLink Underline="Underline.Hover"
                 Color="Color.Inherit"
                 OnClick="@(() => OnSort(field))"
                 Style="cursor:pointer; display:inline-flex; align-items:center; gap:2px;">
        @label
        @if (_sortField == field)
        {
            <MudIcon Icon="@(_sortDescending ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)"
                      Size="Size.Small" />
        }
    </MudLink>;

    private void RebuildPage() =>
        _paged = _all.Skip((_page - 1) * _pageSize).Take(_pageSize).ToList();

    private void OnPageChanged(int page) { _page = page; RebuildPage(); }

    private void OnPageSizeChanged(int size) { _pageSize = size; _page = 1; RebuildPage(); }

    private async Task RefreshAsync() => await LoadAsync();

    private void OpenDetail(RunSummary b) =>
        TabService.OpenOrFocus(TabModel.CreateRunDetail(b.RunId, b.RunId, Environment));

    private void OpenTimeline(RunSummary b) =>
        TabService.OpenOrFocus(TabModel.CreateTimeline(b.RunId, Environment));

    private async Task StopRunAsync(RunSummary b)
    {
        var ok = await RunService.CancelRunAsync(Environment, b.RunId, _cts.Token);
        if (ok)
        {
            Snackbar.Add($"Stop requested for {b.RunId}", Severity.Warning);
            await LoadAsync();
        }
        else
            Snackbar.Add("Could not stop run", Severity.Error);
    }

    private static string FormatDuration(TimeSpan ts) =>
        ts.TotalHours >= 1
            ? $"{(int)ts.TotalHours:D2}:{ts.Minutes:D2}:{ts.Seconds:D2}"
            : $"{ts.Minutes:D2}:{ts.Seconds:D2}";

    public void Dispose() => _cts.Cancel();
}
