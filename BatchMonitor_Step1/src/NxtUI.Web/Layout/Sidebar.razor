@inject TabService TabService
@inject EnvironmentSelectorService EnvService
@inject IJSRuntime JS
@using Microsoft.JSInterop
@implements IAsyncDisposable

<MudDrawer @bind-Open="_drawerOpen"
           Variant="DrawerVariant.Mini"
           MiniWidth="56px"
           Width="168px"
           Elevation="0"
           Class="bm-sidebar"
           OpenMiniOnHover="false">

    <div class="bm-sidebar-content">

        <!-- ── Header: burger + title rendered as a nav item so it matches other items ───────── -->
        <div class="bm-sidebar-header">
            <SidebarNavItem Icon="@Icons.Material.Outlined.Menu"
                            Label="NxtUI"
                            IsOpen="@_drawerOpen"
                            OnClick="ToggleDrawer" />
        </div>

        <!-- ── Nav items (top section) ───────────────────────────────── -->
        <div class="bm-nav-menu">

            <SidebarNavItem Icon="@Icons.Material.Outlined.Home"
                            Label="Home"
                            IsOpen="@_drawerOpen"
                            IsActive="@(TabService.ActiveTab is null)"
                            OnClick="GoHome" />

            <SidebarNavItem Icon="@Icons.Material.Outlined.ViewList"
                            Label="Runs"
                            IsOpen="@_drawerOpen"
                            IsActive="@IsTabActive($"dashboard:runs:{EnvService.SelectedId}")"
                            OnClick="@(() => Open(TabModel.CreateRunsDashboard(EnvService.SelectedId)))" />

            <SidebarNavItem Icon="@Icons.Material.Outlined.ListAlt"
                            Label="Batches"
                            IsOpen="@_drawerOpen"
                            IsActive="@IsTabActive($"dashboard:batches:{EnvService.SelectedId}")"
                            OnClick="@(() => Open(TabModel.CreateBatchesDashboard(EnvService.SelectedId)))" />

            <SidebarNavItem Icon="@Icons.Material.Outlined.Dns"
                            Label="Services"
                            IsOpen="@_drawerOpen"
                            IsActive="@IsTabActive($"dashboard:services:{EnvService.SelectedId}")"
                            OnClick="@(() => Open(TabModel.CreateServicesDashboard(EnvService.SelectedId)))" />

            <SidebarNavItem Icon="@Icons.Material.Outlined.AccountTree"
                            Label="Pipelines"
                            IsOpen="@_drawerOpen"
                            IsActive="@IsTabActive($"dashboard:pipelines:{EnvService.SelectedId}")"
                            OnClick="@(() => Open(TabModel.CreatePipelinesDashboard(EnvService.SelectedId)))" />

            <SidebarNavItem Icon="@Icons.Material.Outlined.Stream"
                            Label="Kafka"
                            IsOpen="@_drawerOpen"
                            IsActive="@IsTabActive($"dashboard:kafka:{EnvService.SelectedId}")"
                            OnClick="@(() => Open(TabModel.CreateKafkaDashboard(EnvService.SelectedId)))" />

<SidebarNavItem Icon="@Icons.Material.Outlined.Storage"
                            Label="MongoDB"
                            IsOpen="@_drawerOpen"
                            IsActive="@IsTabActive($"dashboard:mongo:{EnvService.SelectedId}")"
                            OnClick="@(() => Open(TabModel.CreateMongoDashboard(EnvService.SelectedId)))" />

            <SidebarNavItem Icon="@Icons.Material.Outlined.Tune"
                            Label="Config"
                            IsOpen="@_drawerOpen"
                            IsActive="@IsTabActive($"dashboard:config:{EnvService.SelectedId}")"
                            OnClick="@(() => Open(TabModel.CreateConfigDashboard(EnvService.SelectedId)))" />

            <SidebarNavItem Icon="@Icons.Material.Outlined.Article"
                            Label="Logs"
                            IsOpen="@_drawerOpen"
                            IsActive="@IsTabActive($"dashboard:logs:{EnvService.SelectedId}")"
                            OnClick="@(() => Open(TabModel.CreateLogsDashboard(EnvService.SelectedId)))" />

        </div>

        <!-- ── Bottom section ────────────────────────────────────────── -->
        <div class="bm-sidebar-bottom">

            <!-- Environment selector — compact badge-only but wide enough to avoid cropping -->
            @if (_drawerOpen)
            {
                <div class="bm-env-selector-expanded">
                    <MudSelect T="string"
                               Value="@EnvService.SelectedId"
                               ValueChanged="OnEnvChanged"
                               Dense="true"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="bm-env-select">
                        @foreach (var env in EnvService.Environments)
                        {
                            <MudSelectItem Value="@env.Id">
                                <span class="bm-env-badge"
                                      style="background:@env.BadgeColor; color:@env.BadgeTextColor">
                                    @env.Id
                                </span>
                            </MudSelectItem>
                        }
                    </MudSelect>
                </div>
            }
            else
            {
                <div class="bm-env-selector-collapsed">
                    <MudTooltip Text="@EnvService.Selected?.Label" Placement="Placement.Right">
                        <div class="bm-env-badge-mini"
                             style="background:@EnvService.Selected?.BadgeColor; color:@EnvService.Selected?.BadgeTextColor"
                             @onclick="ToggleDrawer">
                            @ShortId(EnvService.Selected?.Id)
                        </div>
                    </MudTooltip>
                </div>
            }

            <div class="bm-sidebar-divider"></div>

            <!-- Settings — below the divider -->
            <SidebarNavItem Icon="@Icons.Material.Outlined.Settings"
                            Label="Settings"
                            IsOpen="@_drawerOpen"
                            IsActive="@IsTabActive("dashboard:settings")"
                            OnClick="@(() => Open(TabModel.CreateSettings()))" />

        </div>
    </div>

</MudDrawer>

@code {
    [Parameter] public EventCallback<bool> DrawerOpenChanged { get; set; }

    private bool _drawerOpen = true;
    private IJSObjectReference? _appModule;

    private bool IsTabActive(string tabId) =>
        TabService.IsOpen(tabId) && TabService.IsActive(tabId);

    protected override void OnInitialized()
    {
        TabService.OnChange += StateHasChanged;
        EnvService.OnChange += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _appModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/app.js?v=4");
        var stored = await _appModule.InvokeAsync<string?>("getLocalStorage", "bm-sidebar-open");
        if (stored is not null)
        {
            _drawerOpen = stored != "false";
            await DrawerOpenChanged.InvokeAsync(_drawerOpen);
            StateHasChanged();
        }
    }

    private async Task ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
        await DrawerOpenChanged.InvokeAsync(_drawerOpen);
        if (_appModule is not null)
            await _appModule.InvokeVoidAsync("setLocalStorage", "bm-sidebar-open", _drawerOpen.ToString().ToLower());
    }

    private void GoHome() => TabService.GoHome();
    private void Open(TabModel tab) => TabService.OpenOrFocus(tab);
    private void OnEnvChanged(string newId) => EnvService.SelectedId = newId;
    private static string ShortId(string? id) => id is null ? "" : id.Length > 4 ? id[..4] : id;

    public async ValueTask DisposeAsync()
    {
        TabService.OnChange -= StateHasChanged;
        EnvService.OnChange -= StateHasChanged;
        if (_appModule is not null)
        {
            try { await _appModule.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }
    }
}
