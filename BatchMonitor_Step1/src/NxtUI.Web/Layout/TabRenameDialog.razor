@namespace NxtUI.Web.Layout
@using MudBlazor
@inject TabService TabService
@inject IJSRuntime JS

<MudDialog>
    <DialogContent>
        <div style="display:flex; flex-direction:column; gap:14px;">

            <span @ref="_fieldRef">
                <MudTextField @ref="_field"
                              @bind-Value="_name"
                              Label="Tab name"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              MaxLength="64"
                              Immediate="true"
                              OnKeyDown="OnKeyDown" />
            </span>

            <div>
                <div style="font-size:0.75rem; color:var(--mud-palette-text-secondary); margin-bottom:6px;">Color</div>
                <div class="bm-icon-picker">
                    <MudTooltip Text="Default (theme color)" Placement="Placement.Top">
                        <div class="bm-color-picker-item @(_selectedColor is null ? "selected" : "")"
                             style="background:var(--mud-palette-surface); border:1px dashed var(--mud-palette-text-secondary);"
                             @onclick="@(() => _selectedColor = null)">
                            <MudIcon Icon="@Icons.Material.Outlined.FormatColorReset" Size="Size.Small" />
                        </div>
                    </MudTooltip>
                    @foreach (var (color, label) in _colors)
                    {
                        var c = color;
                        <MudTooltip Text="@label" Placement="Placement.Top">
                            <div class="bm-color-picker-item @(_selectedColor == c ? "selected" : "")"
                                 style="background:@c;"
                                 @onclick="@(() => _selectedColor = c)"></div>
                        </MudTooltip>
                    }
                </div>
            </div>

            <div>
                <div style="font-size:0.75rem; color:var(--mud-palette-text-secondary); margin-bottom:6px;">Icon</div>
                <div class="bm-icon-picker">
                    @foreach (var (icon, label) in _icons)
                    {
                        var ico = icon;
                        <MudTooltip Text="@label" Placement="Placement.Top">
                            <div class="bm-icon-picker-item @(_selectedIcon == ico ? "selected" : "")"
                                 @onclick="@(() => _selectedIcon = ico)">
                                <MudIcon Icon="@ico" Size="Size.Small"
                                         Style="@(_selectedColor is null ? "" : $"color:{_selectedColor};")" />
                            </div>
                        </MudTooltip>
                    }
                </div>
            </div>

        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Confirm"
                   Disabled="@(string.IsNullOrWhiteSpace(_name))">Rename</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string  TabId             { get; set; } = string.Empty;
    [Parameter] public string  CurrentLabel      { get; set; } = string.Empty;
    [Parameter] public string  CurrentIcon       { get; set; } = string.Empty;
    [Parameter] public string? CurrentIconColor  { get; set; }

