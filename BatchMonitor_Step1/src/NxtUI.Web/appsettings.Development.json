{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },

  "LogPaths": {
    "Templates": [
      "C:\\Temp\\NxtUI-testlogs\\{date}\\Services\\{service}_{env}\\{server}_*_Pid_{pid}"
    ],
    "MetricsFileName": "Metrics.log",
    "CheckIntervalSeconds": 90
  },

  "TestLogGenerator": {
    "Enabled": true,
    "WriteIntervalSeconds": 15,
    "InitialLineCount": 5,
    "TemplateIndex": 0
  }
}
